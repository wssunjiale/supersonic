    "conditional_blocks": {
      "aggregate_percent_metrics": {
        "condition": "需要在 aggregate 模式下展示总量占比列时",
        "fields": {
          "percent_metrics": [
            {
              "expressionType": "SIMPLE",
              "column": {
                "column_name": "sales"
              },
              "aggregate": "SUM",
              "label": "SUM(sales)"
            }
          ],
          "percent_metric_calculation": "row_limit"
        }
      },
      "aggregate_totals": {
        "condition": "需要在 aggregate 模式下展示 summary totals 时",
        "fields": {
          "show_totals": true
        },
        "notes": "会额外生成 totals query。"
      },
      "raw_records_sorting": {
        "condition": "raw 模式需要按字段排序时",
        "fields": {
          "query_mode": "raw",
          "order_by_cols": [
            "[\"order_id\",true]"
          ]
        },
        "notes": "真正进入 query 的是 `extractQueryFields()` 解析出来的 `orderby`。"
      },
      "server_pagination": {
        "condition": "需要服务端分页而不是前端分页时",
        "fields": {
          "server_pagination": true,
          "server_page_length": 20,
          "row_limit": 1000
        },
        "notes": "搜索词、排序列、当前页码不放在 root form_data，而由 ownState `searchText/searchColumn/sortBy/currentPage/pageSize` 驱动。"
      },
      "temporal_bucketization": {
        "condition": "aggregate 模式下按时间列分桶时",
        "fields": {
          "query_mode": "aggregate",
          "groupby": [
            "order_date"
          ],
          "time_grain_sqla": "P1D",
          "temporal_columns_lookup": {
            "order_date": true
          }
        },
        "notes": "`buildQuery.ts` 会把 `order_date` 改写成带 `timeGrain` 的 AdhocColumn。"
      },
      "time_comparison": {
        "condition": "aggregate 模式下需要比较当前值与历史值时",
        "fields": {
          "time_compare": "1 year ago",
          "comparison_type": "values",
          "comparison_color_enabled": true,
          "comparison_color_scheme": "Green"
        },
        "notes": "runtime 会把指标列展开成 `Main / # / △ / %` 四类 comparison columns。"
      },
      "custom_time_comparison": {
        "condition": "使用自定义 comparison 偏移量时",
        "fields": {
          "time_compare": "custom",
          "start_date_offset": "1 year ago",
          "comparison_type": "values"
        }
      },
      "column_customization": {
        "condition": "需要改列名、列宽、格式或 comparison 子列格式时",
        "fields": {
          "column_config": {
            "sum__num": {
              "d3NumberFormat": ".3s",
              "columnWidth": 180,
              "customColumnName": "Sales"
            },
            "Main metric_1": {
              "d3NumberFormat": ".2f"
            },
            "# metric_1": {
              "d3NumberFormat": ".1f"
            }
          }
        }
      },
      "html_rendering": {
        "condition": "单元格值包含 HTML 且需要按 HTML 方式渲染时",
        "fields": {
          "allow_render_html": true
        }
      },
      "conditional_formatting": {
        "condition": "需要对数值列做阈值着色时",
        "fields": {
          "conditional_formatting": [
            {
              "column": "sum__num",
              "operator": ">",
              "targetValue": 2467,
              "colorScheme": "#ACE1C4"
            }
          ]
        }
      }
    },
    "runtime_only_or_non_template_fields": {
      "display_or_hidden_controls": [
        {
          "field_name": "comparison_range_label",
          "reason": "UI 显示型控件，不应作为 API root form_data 主动填写。"
        }
      ],
      "query_object_only_fields": [
        {
          "field_name": "queries[*].columns",
          "reason": "这是 `all_columns` / `groupby` 经 alias 与 buildQuery 编译后的结果，不是 root 直接键。"
        },
        {
          "field_name": "queries[*].orderby",
          "reason": "这是 `order_by_cols` 或 `timeseries_limit_metric + order_desc` 编译后的 query 字段。"
        },
        {
          "field_name": "queries[*].post_processing",
          "reason": "这是 `percent_metrics` / `time_compare` 派生的 query 字段。"
        },
        {
          "field_name": "queries[*].time_offsets",
          "reason": "这是 `time_compare` / `start_date_offset` 派生的 query 字段。"
        },
        {
          "field_name": "queries[*].row_offset / is_rowcount",
          "reason": "这是 server pagination 运行时派生字段。"
        }
      ],
      "own_state_only": [
        {
          "field_name": "pageSize / currentPage / sortBy / searchText / searchColumn",
          "reason": "这些都不是 root form_data，而是 Table ownState。只有 server pagination 时才影响 buildQuery。"
        }
      ],
      "runtime_aliases_generated_by_transformProps": [
        {
          "field_name": "alignPositiveNegative / colorPositiveNegative / showCellBars / includeSearch / allowRearrangeColumns / allowRenderHtml / comparisonColorEnabled / comparisonColorScheme",
          "reason": "这些是 runtime camelCase props，不是 API root 键。"
        }
      ]
    },
    "api_usage_guidance": {
      "high_confidence_required_fields": [
        "datasource",
        "viz_type",
        "query_mode",
        "aggregate 模式下：groupby / metrics / percent_metrics 三者至少一类非空",
        "raw 模式下：all_columns 至少一项"
      ],
      "recommended_always_set": [
        "adhoc_filters",
        "row_limit",
        "table_timestamp_format",
        "allow_render_html",
        "conditional_formatting"
      ],
      "avoid_confusion": [
        "不要把 `all_columns` 写成 `columns`；`columns` 是 query object 字段，不是 Table root control name。",
        "不要把 `order_by_cols` 写成 `orderby`；`orderby` 是 query object 字段，不是 Table root control name。",
        "不要把 runtime 字段 `allowRenderHtml`、`includeSearch`、`showCellBars`、`comparisonColorEnabled` 写回 root form_data。",
        "如果你要的是 raw 表，不要只传 `all_columns` 而省略 `query_mode`；虽然源码能推断，但显式传更稳。"
      ]
    }
  },
