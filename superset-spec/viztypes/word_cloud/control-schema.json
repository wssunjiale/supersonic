      "useLegacyApi": false,
      "frontend_request_endpoint": "/api/v1/chart/data",
      "build_query": "Word Cloud/buildQuery.ts 只在 `sort_by_metric=true` 时追加 `orderby=[[metric,false]]`；其余 query fields 走标准 buildQueryContext / extractQueryFields 路径。",
      "core_aliasing": "core `extractQueryFields()` 会把 root `series` 归并到 query.columns，把 root `metric` 归并到 query.metrics。"
    },
    "query_compilation": {
      "query_columns": "`series` 通过 `series -> groupby -> columns` 的 core alias 路径进入 query.columns。buildQuery 测试验证：`series='foo'` 时，query.columns = ['foo']。",
      "query_metrics": "`metric` 为非空时进入 query.metrics；为空时可以只查维度列并用统一默认字号渲染词云。",
      "query_filters": "`adhoc_filters` 由标准 buildQueryObject/processFilters 路径编译进 query。",
      "query_limits": "`row_limit` 由标准 query object 路径写入 query.row_limit。",
      "query_sorting": "`sort_by_metric=true` 时，buildQuery 会把 `orderby` 改成 `[[metric,false]]`；否则保持默认。"
    },
