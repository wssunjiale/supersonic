  },
  "recommended_extra_form_data_template": {
    "filters": [
      {
        "col": "country",
        "op": "IN",
        "val": [
          "CN",
          "US"
        ]
      }
    ],
    "adhoc_filters": [
      {
        "expressionType": "SIMPLE",
        "clause": "WHERE",
        "subject": "country",
        "operator": "IN",
        "comparator": [
          "CN",
          "US"
        ]
      }
    ],
    "custom_form_data": {}
  },
  "unsafe_root_form_data_changes": [
    {
      "field_name": "slice_id",
      "reason": "与保存态图表 id 不一致会被后端立即判定为请求了另一张图。"
    },
    {
      "field_name": "datasource / viz_type",
      "reason": "guest embedding 不应修改图表绑定的数据集或图表类型。"
    },
    {
      "field_name": "source / target",
      "reason": "它们会被 `buildQuery.ts` 编译成 query `groupby`。"
    },
    {
      "field_name": "metric",
      "reason": "`extractQueryFields()` 会把它折叠成 query `metrics`。"
    },
    {
      "field_name": "adhoc_filters / row_limit",
      "reason": "会改变实际查询条件和返回结果规模。"
    },
    {
      "field_name": "sort_by_metric",
      "reason": "会决定 `buildQuery.ts` 是否生成 query `orderby`。"
    },
    {
      "field_name": "color_scheme",
      "reason": "虽然不改 SQL，但会改变图表定义与节点配色。"
    }
  ],
  "practical_guidance": {
    "best_practice": [
      "先从保存态 Sankey Chart 读取完整 form_data。",
      "根层字段保持不变，尤其保留 `source`、`target`、`metric`、`adhoc_filters`、`row_limit`、`sort_by_metric` 和 `color_scheme`。",
      "只在 `extra_form_data` 中放动态 `filters` / `adhoc_filters`。",
      "如果第三方页面需要联动筛选，不要期待 Sankey 自己从图上点击发出 cross-filter；当前插件还没实现。"
    ],
    "avoid": [
      "不要在 guest embedding 请求里重构 Sankey 的 `source` / `target` / `metric`。",
      "不要给 root form_data 额外补一个 `groupby` 试图替代 `source` / `target`。",
      "不要把 runtime 别名 `colorScheme` 当成 root 键。"
    ]
  }
}
