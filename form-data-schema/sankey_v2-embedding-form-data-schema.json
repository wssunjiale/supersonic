{
  "viz_type": "sankey_v2",
  "display_name": "Sankey Chart",
  "purpose": "第三方 embedding / guest token 场景下安全传输的 Sankey Chart form_data 模板",
  "base_form_data_schema_file": "D:/vsx/metrics/supersonic/form-data-schema/sankey_v2-form-data-schema.json",
  "source_files": [
    "D:/vsx/sources/superset-6.0.0/superset/security/manager.py",
    "D:/vsx/sources/superset-6.0.0/superset/charts/data/api.py",
    "D:/vsx/sources/superset-6.0.0/superset/commands/chart/data/get_data_command.py",
