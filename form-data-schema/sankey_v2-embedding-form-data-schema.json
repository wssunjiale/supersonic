    "D:/vsx/sources/superset-6.0.0/superset-frontend/plugins/plugin-chart-echarts/src/Sankey/transformProps.ts",
    "D:/vsx/sources/superset-6.0.0/superset-frontend/plugins/plugin-chart-echarts/src/Sankey/index.ts",
    "D:/vsx/sources/superset-6.0.0/superset-frontend/packages/superset-ui-core/src/query/buildQueryContext.ts",
    "D:/vsx/sources/superset-6.0.0/superset-frontend/packages/superset-ui-core/src/query/buildQueryObject.ts",
    "D:/vsx/sources/superset-6.0.0/superset-frontend/packages/superset-ui-core/src/query/types/QueryFormData.ts",
    "D:/vsx/sources/superset-6.0.0/superset-frontend/packages/superset-ui-core/src/query/processExtraFormData.ts"
  ],
  "notes": [
    "embedded guest 的核心限制在后端 `security/manager.py::query_context_modified()`。报错原文是 `Guest user cannot modify chart payload`。",
    "Sankey 走 chart data API 的 query context。`buildQueryContext()` 会把 raw form_data 原样保存在 `query_context.form_data`，同时 `Sankey/buildQuery.ts` 会把 `source` 与 `target` 编译进 query `groupby`。",
    "当前 Sankey 插件 metadata 中直接写了 `TODO: Implement cross filtering`，因此它不像 radar 一样从图形点击事件发出 `extraFormData.filters`。embedding 场景里如果要做动态过滤，需要调用方自己传 `extra_form_data.filters` / `adhoc_filters`。",
    "`sort_by_metric=true` 会改变 query `orderby`，guest 场景不应动态修改它。"
  ],
  "security_enforcement": {
    "backend_check_function": "superset/security/manager.py::query_context_modified",
    "checked_when": "ChartDataCommand.validate() -> QueryContext.raise_for_access()",
    "error_message": "Guest user cannot modify chart payload",
    "directly_compared_root_fields": [
      "slice_id",
      "metrics",
      "columns",
      "groupby",
      "orderby"
    ],
    "sankey_specific_query_sensitive_fields": [
      "source",
      "target",
      "metric",
      "adhoc_filters",
      "row_limit",
      "sort_by_metric"
    ],
    "recommended_strategy": "复制保存态 Sankey Chart 的完整 form_data 作为 base，只通过 extra_form_data 追加动态过滤条件；不要在 guest 请求里重构 `source/target/metric` 或排序字段。"
  },
  "safe_base_rule": {
    "description": "第三方 embedding 请求中的根层 form_data，应当从已保存 Sankey Chart 的 form_data 直接复制，不要重构。",
    "must_be_copied_from_saved_chart": [
      "slice_id",
      "dashboardId",
      "datasource",
      "viz_type",
      "source",
      "target",
      "metric",
      "adhoc_filters",
      "row_limit",
      "sort_by_metric",
      "color_scheme",
      "all other saved chart-definition fields"
    ],
    "why": [
      "`buildQueryContext()` 会把 raw formData 直接放进 `query_context.form_data`。",
      "`Sankey/buildQuery.ts` 会把 `source` 与 `target` 组装成 query `groupby`，而 `metric` 会进入 query `metrics`。",
      "`sort_by_metric=true` 时会生成 query `orderby`，属于 guest payload 校验关注的敏感查询字段。",
      "颜色方案虽然不改 SQL，但属于图表定义的一部分。复制保存态是最稳妥的 guest 访问策略。"
    ]
  },
  "safe_embedding_form_data_template": {
    "description": "这是 Sankey Chart guest embedding 下的安全写法。根层以保存态图表为 base，仅改 extra_form_data。",
    "template": {
      "slice_id": "<saved_chart_id>",
      "dashboardId": "<dashboard_id>",
      "datasource": "<copied_from_saved_chart>",
      "viz_type": "sankey_v2",
      "source": "<copied_from_saved_chart>",
      "target": "<copied_from_saved_chart>",
      "metric": "<copied_from_saved_chart>",
      "adhoc_filters": "<copied_from_saved_chart>",
      "row_limit": "<copied_from_saved_chart>",
      "sort_by_metric": "<copied_from_saved_chart>",
      "color_scheme": "<copied_from_saved_chart>",
      "extra_form_data": {
        "filters": [
          {
            "col": "country",
            "op": "IN",
            "val": [
              "CN",
              "US"
            ]
          }
        ],
        "adhoc_filters": [
          {
            "expressionType": "SIMPLE",
            "clause": "WHERE",
            "subject": "country",
            "operator": "IN",
            "comparator": [
              "CN",
              "US"
            ]
          }
        ],
        "custom_form_data": {}
      }
    }
  },
  "preferred_dynamic_container": {
    "field_name": "extra_form_data",
    "description": "第三方 embedding 推荐把动态上下文放在这里；后端会在 merge_extra_form_data() 中合并它。",
    "append_keys": [
      "adhoc_filters",
      "filters",
      "interactive_groupby",
      "interactive_highlight",
      "interactive_drilldown",
      "custom_form_data"
    ],
    "override_keys_backend_high_confidence": [
      "granularity_sqla",
      "time_column",
      "time_grain",
      "time_range",
      "time_grain_sqla",
      "relative_start",
      "relative_end"
    ],
    "notes": "Sankey 当前没有时间控件链路，也没有 cross-filter 实现。对当前图而言，高置信动态入口仍然只有 `filters` / `adhoc_filters`。"
  },
  "extra_form_data_field_schema": [
    {
      "field_name": "filters",
      "data_type": "array[QueryObjectFilterClause]",
      "behavior": "append",
      "safe_for_sankey_v2": true,
      "recommended": true,
      "sample_data": [
        {
          "col": "country",
          "op": "IN",
          "val": [
            "CN",
            "US"
          ]
        }
      ],
      "effect": "追加普通过滤条件。Sankey 本身没有交互 cross-filter，但调用方可以在 guest 请求里显式传入。",
      "source": "superset/constants.py"
    },
    {
      "field_name": "adhoc_filters",
      "data_type": "array[object]",
      "behavior": "append",
      "safe_for_sankey_v2": true,
      "recommended": true,
      "sample_data": [
        {
          "expressionType": "SIMPLE",
          "clause": "WHERE",
          "subject": "country",
          "operator": "IN",
          "comparator": [
            "CN",
            "US"
          ]
        }
      ],
      "effect": "追加 adhoc filters；后端会把它们标记为 extra 并并入查询。",
      "source": "superset/constants.py + superset/utils/core.py"
    },
    {
      "field_name": "custom_form_data",
      "data_type": "object",
      "behavior": "append",
      "safe_for_sankey_v2": true,
      "recommended": false,
      "sample_data": {},
      "effect": "传递非标准附加数据；Sankey 默认 buildQuery/transformProps 不直接消费它。",
      "source": "QueryFormData.ts + superset/constants.py"
    },
    {
      "field_name": "time_range",
      "data_type": "string",
      "behavior": "override",
      "safe_for_sankey_v2": false,
      "recommended": false,
      "sample_data": "Last 30 days",
      "effect": "通用 extra_form_data override 白名单允许该 key，但 Sankey 当前没有显式时间过滤控件链路。",
      "source": "superset/constants.py + QueryFormData.ts",
      "status": "低置信，不建议在 guest embedding 中依赖"
    },
    {
      "field_name": "time_grain_sqla",
      "data_type": "string | null",
      "behavior": "override",
      "safe_for_sankey_v2": false,
      "recommended": false,
      "sample_data": "P1D",
      "effect": "通用时间粒度 override；当前图没有对应控件。",
      "source": "superset/constants.py + QueryFormData.ts",
      "status": "低置信，不建议在 guest embedding 中依赖"
    },
    {
      "field_name": "granularity_sqla",
      "data_type": "string | null",
      "behavior": "override",
      "safe_for_sankey_v2": false,
      "recommended": false,
      "sample_data": "order_date",
      "effect": "通用时间列 override；当前图没有对应控件。",
      "source": "superset/constants.py + QueryFormData.ts",
      "status": "低置信，不建议在 guest embedding 中依赖"
    },
    {
      "field_name": "time_column",
      "data_type": "string | null",
      "behavior": "override",
      "safe_for_sankey_v2": false,
      "recommended": false,
      "sample_data": "order_date",
      "effect": "底层 QueryObject 时间列 override；当前图没有官方时间控件闭环。",
      "source": "superset/constants.py + QueryFormData.ts",
      "status": "低置信，不建议在 guest embedding 中依赖"
    },
    {
      "field_name": "time_grain",
      "data_type": "string | null",
      "behavior": "override",
      "safe_for_sankey_v2": false,
      "recommended": false,
      "sample_data": "P1D",
