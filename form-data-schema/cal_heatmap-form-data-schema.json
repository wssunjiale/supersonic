  "minimal_form_data_template": {
    "datasource": "<dataset_id>__table",
    "viz_type": "cal_heatmap",
    "granularity_sqla": "<temporal_column>",
    "time_range": "2025-01-01 : 2025-01-31",
    "domain_granularity": "month",
    "subdomain_granularity": "day",
    "metrics": [
      "count"
    ],
    "adhoc_filters": []
  },
  "recommended_form_data_template": {
    "datasource": "<dataset_id>__table",
    "viz_type": "cal_heatmap",
    "granularity_sqla": "ds",
    "time_range": "2025-01-01 : 2025-01-31",
    "domain_granularity": "month",
    "subdomain_granularity": "day",
    "metrics": [
      "count"
    ],
    "adhoc_filters": [],
    "linear_color_scheme": "superset_seq_1",
    "cell_size": 10,
    "cell_padding": 2,
    "cell_radius": 0,
    "steps": 10,
    "y_axis_format": "SMART_NUMBER",
    "x_axis_time_format": "smart_date",
    "show_legend": true,
    "show_values": false,
    "show_metric_name": true
  },
  "conditional_blocks": {
    "multiple_metrics": {
      "condition": "需要按多个指标分别渲染多个日历块时",
      "fields": {
        "metrics": [
          "count",
          {
            "expressionType": "SIMPLE",
            "column": {
              "column_name": "sales"
            },
            "aggregate": "SUM",
            "label": "SUM(sales)"
          }
        ],
        "show_metric_name": true
      }
    },
    "legacy_since_until_pair": {
      "condition": "如果调用方仍沿用 legacy since/until 形式，而不是 time_range",
      "fields": {
        "since": "2019-01-01",
        "until": "2019-02-01"
      }
    },
    "filters": {
      "condition": "需要筛选参与聚合的底层数据时",
      "fields": {
        "adhoc_filters": [
          {
            "expressionType": "SIMPLE",
            "clause": "WHERE",
            "subject": "region",
            "operator": "IN",
            "comparator": [
              "East"
            ]
          }
        ]
      }
    },
    "hourly_calendar": {
      "condition": "需要按天域展示小时级热力块时",
      "fields": {
        "domain_granularity": "day",
        "subdomain_granularity": "hour"
      }
    },
    "weekly_calendar": {
      "condition": "需要按月域展示周级热力块时",
      "fields": {
        "domain_granularity": "month",
        "subdomain_granularity": "week"
      }
    },
    "show_cell_values": {
      "condition": "需要在单元格内部直接显示数值时",
      "fields": {
        "show_values": true,
        "y_axis_format": "SMART_NUMBER"
      }
    },
    "layout_and_colors": {
      "condition": "需要调整单元格大小、间距、圆角和颜色步长时",
      "fields": {
        "linear_color_scheme": "superset_seq_1",
        "cell_size": 12,
        "cell_padding": 2,
        "cell_radius": 1,
        "steps": 10
      }
    }
  },
  "runtime_only_or_non_template_fields": {
    "legacy_or_confusing_keys": [
      {
        "field_name": "metric",
        "reason": "旧切片曾使用单值 `metric`。2018 年迁移脚本已把它迁移成 `metrics` 数组，Superset 6.0.0 的正式模板应使用 `metrics`。"
      },
      {
        "field_name": "time_grain_sqla",
        "reason": "当前图的查询粒度由 `subdomain_granularity` 在后端映射生成。即使 root 里存在 `time_grain_sqla`，CalHeatmapViz.query_obj() 也会覆盖它。"
      }
    ],
    "runtime_aliases_generated_by_transformProps": [
      {
        "field_name": "domainGranularity",
        "reason": "由 raw form_data.domain_granularity 派生的运行时别名，不是 API root 键。"
      },
      {
        "field_name": "subdomainGranularity",
        "reason": "由 raw form_data.subdomain_granularity 派生的运行时别名，不是 API root 键。"
      },
      {
        "field_name": "linearColorScheme",
        "reason": "由 raw form_data.linear_color_scheme 派生的运行时别名，不是 API root 键。"
      },
      {
        "field_name": "cellSize",
        "reason": "由 raw form_data.cell_size 派生的运行时别名，不是 API root 键。"
      },
      {
        "field_name": "showLegend",
        "reason": "由 raw form_data.show_legend 派生的运行时别名，不是 API root 键。"
      }
    ],
    "backend_response_only_fields": [
      {
        "field_name": "queriesData[0].data.start",
        "reason": "这是后端 CalHeatmapViz.get_data() 计算出的起始时间戳，不是 root form_data 字段。"
      },
      {
        "field_name": "queriesData[0].data.range",
        "reason": "这是后端根据 domain_granularity 与时间跨度计算出的 domain 数量，不是 root form_data 字段。"
      },
      {
        "field_name": "queriesData[0].data.data",
        "reason": "这是按 metric label 分组、按秒级时间戳编码的查询结果字典，不是 root form_data 字段。"
      }
    ],
    "viz_switch_only": [
      {
        "field_name": "formDataOverrides(metrics)",
        "reason": "只在 standardized form data 切换 viz_type 时把 standardized metrics 列表迁移到当前图的 `metrics` 字段，不是常规 API 导出 form_data 的必经步骤。"
      }
    ]
  },
  "api_usage_guidance": {
    "high_confidence_required_fields": [
      "datasource",
      "viz_type",
      "granularity_sqla",
      "time_range",
      "domain_granularity",
      "subdomain_granularity",
      "metrics"
    ],
    "recommended_always_set": [
      "adhoc_filters",
      "linear_color_scheme",
      "cell_size",
      "cell_padding",
      "cell_radius",
      "steps",
      "y_axis_format",
      "x_axis_time_format",
      "show_legend",
      "show_values",
      "show_metric_name"
    ],
    "avoid_confusion": [
      "不要把当前正式指标字段写成旧的 `metric`；Superset 6.0.0 正式字段是 `metrics`。",
      "不要尝试用 root `time_grain_sqla` 来控制格子粒度；当前图后端会用 `subdomain_granularity` 覆盖它。",
      "不要把运行时别名 `domainGranularity`、`subdomainGranularity`、`linearColorScheme`、`cellSize` 写回 root form_data。",
      "如果不提供可解析的时间边界，CalHeatmapViz.get_data() 会直接报错；最稳妥的写法是显式传 `time_range`。"
    ]
  }
