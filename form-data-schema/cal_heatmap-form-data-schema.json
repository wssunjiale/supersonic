  "notes": [
    "Calendar Heatmap 是 legacy 图，真实请求路径是 `/superset/explore_json/`，不是 `/api/v1/chart/data`。",
    "Explore 导出 form_data 时走 `getFormDataFromControls()`，它按 control name 原样写入 root form_data，因此保存态字段保持 snake_case，例如 `domain_granularity`、`subdomain_granularity`、`linear_color_scheme`。",
    "前端运行时看到的 `domainGranularity`、`subdomainGranularity`、`linearColorScheme`、`cellSize`、`showLegend` 等 camelCase 名称来自运行时 formData 映射，不是 API root 键名。",
    "CalHeatmapViz.query_obj() 会把 `subdomain_granularity` 映射成 `extras.time_grain_sqla`，因此当前图真正驱动查询粒度的是 `subdomain_granularity`。",
    "CalHeatmapViz.get_data() 会再次解析 `time_range / since / until`。如果无法解析出完整时间边界，会抛出 `Please provide both time bounds (Since and Until)`。",
    "2018 年迁移脚本把旧的 `metric` 键迁移成 `metrics` 数组。Superset 6.0.0 的正式模板应使用 `metrics`。"
  ],
  "naming_and_pipeline": {
    "control_to_api_form_data": "getFormDataFromControls() 直接把 controls[name].value 写成 form_data[name]。",
    "api_form_data_to_backend_request": "ChartClient.ts 在 `useLegacyApi=true` 时，把原始 form_data 包装成 `{ form_data }` POST 到 `/superset/explore_json/`。",
    "backend_form_data_normalization": "`explore_json()` 会先补 `datasource`，再执行 `convert_legacy_filters_into_adhoc(form_data)` 与 `merge_extra_filters(form_data)`。",
    "backend_form_data_to_query_obj": "`CalHeatmapViz.query_obj()` 会把 `form_data.metrics` 直接写入 `query_obj.metrics`，并用 `subdomain_granularity` 覆盖 `query_obj.extras.time_grain_sqla`。"
  },
  "global_required_fields": {
    "datasource": {
      "data_type": "string",
      "required": true,
      "sample_data": "<dataset_id>__table",
      "source": "explore_json() + datasourceAndVizType hidden control"
    },
    "viz_type": {
      "data_type": "string",
      "required": true,
      "fixed_value": "cal_heatmap",
      "source": "CalHeatmapViz.viz_type + Calendar/index.js"
    },
    "granularity_sqla": {
      "data_type": "string | object",
      "required": true,
      "sample_data": "ds",
      "source": "Time section + CalHeatmapViz/BaseViz query path"
    },
    "time_range": {
      "data_type": "string",
      "required": true,
      "sample_data": "2008-01-01 : 2008-02-01",
      "source": "Time section + CalHeatmapViz.get_data()",
      "notes": "若不用 time_range，则至少要提供 legacy `since` + `until`。"
    },
    "domain_granularity": {
      "data_type": "string",
      "required": true,
      "sample_data": "month",
      "source": "Query section"
    },
    "subdomain_granularity": {
      "data_type": "string",
      "required": true,
      "sample_data": "day",
      "source": "Query section + CalHeatmapViz.query_obj()"
    },
    "metrics": {
      "data_type": "array[string | object]",
      "required": true,
      "sample_data": [
        "count"
      ],
      "source": "Query section"
    }
  },
  "global_optional_fields": {
