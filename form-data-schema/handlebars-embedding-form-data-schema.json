{
  "viz_type": "handlebars",
  "display_name": "Handlebars",
  "purpose": "第三方 embedding / guest token 场景下安全传输的 Handlebars form_data 模板",
  "base_form_data_schema_file": "D:/vsx/metrics/supersonic/form-data-schema/handlebars-form-data-schema.json",
  "source_files": [
