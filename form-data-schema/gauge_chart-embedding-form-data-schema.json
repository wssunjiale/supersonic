  "unsafe_root_form_data_changes": [
    {
      "field_name": "slice_id",
      "reason": "与保存态图表 id 不一致会被后端立即判定为请求了另一张图。"
    },
    {
      "field_name": "metric",
      "reason": "它会进入 `query.metrics`，guest 模式下不应在根层修改。"
    },
    {
      "field_name": "groupby",
      "reason": "它会进入 `query.columns`，并决定 click cross-filter 生成哪些列过滤。"
    },
    {
      "field_name": "sort_by_metric",
      "reason": "它会决定 `query.orderby` 是否存在，因此属于高敏感查询字段。"
    },
    {
      "field_name": "datasource",
      "reason": "embedded guest 不应改图表绑定数据集。"
    },
    {
      "field_name": "viz_type",
      "reason": "embedded guest 不应把已分享图表改成另一种图。"
    }
  ],
  "practical_guidance": {
    "best_practice": [
      "先从保存态 Gauge 图表读取完整 form_data。",
      "根层字段保持不变，尤其保留 `metric`、`groupby` 和 `sort_by_metric`。",
      "只在 `extra_form_data` 中放动态 `filters` / `adhoc_filters`。",
      "如果这张 Gauge 本来就没有 `groupby`，它的 chart 内点击不会产生 cross-filter；此时外部过滤更应由宿主页面直接构造 `extra_form_data`。"
    ],
    "avoid": [
      "不要在 guest embedding 请求里手工重写 `metric`、`groupby` 或 `sort_by_metric`。",
      "不要把 runtime camelCase 字段名当成 API root 键名。",
      "不要把 `filters` 和 `adhoc_filters` 直接覆盖到根层保存态字段，优先放在 `extra_form_data`。"
    ]
  }
}
