  "notes": [
    "embedded guest 的核心限制在后端 `security/manager.py::query_context_modified()`。报错原文是 `Guest user cannot modify chart payload`。",
    "Gauge 是标准 chart data API 图表。guest 请求的安全写法仍然是复制保存态 chart form_data 作为 base，只把动态条件放进 `extra_form_data`。",
    "Gauge 的核心敏感根字段是 `metric`、`groupby` 和 `sort_by_metric`：`metric` 会进入 `query.metrics`，`groupby` 会进入 `query.columns`，`sort_by_metric=true` 会额外生成 `query.orderby`。",
    "`allEventHandlers(props)` 为 Gauge 复用了通用 click/contextmenu 逻辑。只有 `groupby.length > 0` 时，点击 gauge item 才会生成 `extraFormData.filters`。",
    "`min_val`、`max_val`、`intervals`、`value_formatter` 等大多只影响显示层，不属于 `query_context_modified()` 的核心比较对象；但 guest 场景仍建议根层原样复制，以免与保存态图表分叉。"
  ],
  "security_enforcement": {
    "backend_check_function": "superset/security/manager.py::query_context_modified",
    "validation_entry": "superset/charts/data/api.py -> ChartDataCommand.validate() -> QueryContext.raise_for_access()",
    "error_message": "Guest user cannot modify chart payload",
    "hard_block_fields": [
      "slice_id",
      "metrics",
      "groupby",
      "columns",
      "orderby"
    ],
    "indirectly_sensitive_fields_for_gauge": [
      "metric",
      "groupby",
      "sort_by_metric"
    ],
    "recommended_strategy": "复制保存态 chart form_data 作为 base，仅通过 extra_form_data 追加过滤条件。"
  },
  "safe_base_rule": {
    "description": "第三方 embedding 请求中的根层 form_data，应直接复制保存态 Gauge 图表的 form_data，不要自行重构查询定义。",
    "must_be_copied_from_saved_chart": [
      "slice_id",
      "datasource",
      "viz_type",
      "metric",
      "groupby",
      "adhoc_filters",
      "row_limit",
      "sort_by_metric",
      "min_val",
      "max_val",
      "start_angle",
      "end_angle",
      "color_scheme",
      "font_size",
      "number_format",
      "currency_format",
      "value_formatter",
      "show_pointer",
      "animation",
      "show_axis_tick",
      "show_split_line",
      "split_number",
      "show_progress",
      "overlap",
      "round_cap",
      "intervals",
      "interval_color_indices",
      "all other saved chart definition fields"
    ],
    "why": [
      "`query_context_modified()` 会比较请求中的 `queries[*].metrics`、`queries[*].columns`、`queries[*].orderby` 与保存态图表是否一致。",
      "Gauge 的 `metric`、`groupby`、`sort_by_metric` 会直接影响这些被比较的 query 字段。",
      "为了最大化避免 guest payload 差异，最安全的方式仍然是根层完全复制保存态。"
    ]
  },
  "safe_embedding_form_data_template": {
    "description": "这是 guest embedding 下的安全写法。根层以保存态 Gauge 图表为 base，仅改 extra_form_data。",
    "template": {
      "slice_id": "<saved_chart_id>",
      "dashboardId": "<dashboard_id>",
      "datasource": "<copied_from_saved_chart>",
      "viz_type": "gauge_chart",
      "metric": "<copied_from_saved_chart>",
      "groupby": "<copied_from_saved_chart>",
      "adhoc_filters": "<copied_from_saved_chart>",
      "row_limit": "<copied_from_saved_chart_if_present>",
      "sort_by_metric": "<copied_from_saved_chart_if_present>",
      "min_val": "<copied_from_saved_chart_if_present>",
      "max_val": "<copied_from_saved_chart_if_present>",
      "start_angle": "<copied_from_saved_chart_if_present>",
      "end_angle": "<copied_from_saved_chart_if_present>",
      "color_scheme": "<copied_from_saved_chart_if_present>",
      "font_size": "<copied_from_saved_chart_if_present>",
      "number_format": "<copied_from_saved_chart_if_present>",
      "currency_format": "<copied_from_saved_chart_if_present>",
      "value_formatter": "<copied_from_saved_chart_if_present>",
      "show_pointer": "<copied_from_saved_chart_if_present>",
      "animation": "<copied_from_saved_chart_if_present>",
      "show_axis_tick": "<copied_from_saved_chart_if_present>",
      "show_split_line": "<copied_from_saved_chart_if_present>",
      "split_number": "<copied_from_saved_chart_if_present>",
      "show_progress": "<copied_from_saved_chart_if_present>",
      "overlap": "<copied_from_saved_chart_if_present>",
      "round_cap": "<copied_from_saved_chart_if_present>",
      "intervals": "<copied_from_saved_chart_if_present>",
      "interval_color_indices": "<copied_from_saved_chart_if_present>",
      "extra_form_data": {
        "filters": [
          {
            "col": "name",
            "op": "IN",
            "val": [
              "Speed"
            ]
          }
        ],
        "adhoc_filters": [
          {
            "expressionType": "SIMPLE",
            "clause": "WHERE",
            "subject": "region",
            "operator": "IN",
            "comparator": [
              "East"
            ]
          }
        ],
        "custom_form_data": {}
      }
    }
  },
  "preferred_dynamic_container": {
    "field_name": "extra_form_data",
    "description": "第三方 embedding 允许动态传入的上下文容器；后端会在 `merge_extra_form_data()` 中把它并入实际查询。",
    "append_keys": [
      "adhoc_filters",
      "filters",
      "interactive_groupby",
      "interactive_highlight",
      "interactive_drilldown",
      "custom_form_data"
    ],
    "override_keys_backend_high_confidence": [
      "granularity_sqla",
      "granularity",
      "time_column",
      "time_grain",
      "time_range",
      "time_compare",
      "time_grain_sqla",
      "relative_start",
      "relative_end"
    ],
    "notes": "Gauge 当前 controlPanel 没有标准时间配置，因此 guest embedding 的主要动态入口仍然是 `filters` 和 `adhoc_filters`。"
  },
  "extra_form_data_field_schema": [
    {
      "field_name": "filters",
      "data_type": "array[QueryObjectFilterClause]",
      "behavior": "append",
      "safe_for_gauge": true,
      "recommended": true,
      "sample_data": [
        {
          "col": "name",
          "op": "IN",
          "val": [
            "Speed"
          ]
        }
      ],
      "effect": "追加 simple filters；后端会把它们转换为额外 adhoc filters 并并入查询。Gauge 的 click cross-filter 也是这个形状。",
      "source": "superset/constants.py + superset/utils/core.py + plugin-chart-echarts/utils/eventHandlers.ts"
    },
    {
      "field_name": "adhoc_filters",
      "data_type": "array[AdhocFilter]",
      "behavior": "append",
      "safe_for_gauge": true,
      "recommended": true,
      "sample_data": [
        {
          "expressionType": "SIMPLE",
          "clause": "WHERE",
          "subject": "region",
          "operator": "IN",
          "comparator": [
            "East"
          ]
        }
      ],
      "effect": "追加 adhoc filters；后端会标记为 `isExtra` 并并入查询。",
      "source": "superset/utils/core.py"
    },
    {
      "field_name": "custom_form_data",
      "data_type": "object",
      "behavior": "append",
      "safe_for_gauge": true,
      "recommended": false,
      "sample_data": {},
      "effect": "可传递非标准附加数据；Gauge 默认 buildQuery / transformProps 不直接消费它。",
      "source": "frontend QueryFormData.ts"
    },
    {
      "field_name": "time_range",
      "data_type": "string",
      "behavior": "override",
      "safe_for_gauge": false,
      "recommended": false,
      "sample_data": "Last 7 days",
      "effect": "这是通用 extra_form_data override 字段，但 Gauge 当前 controlPanel 不依赖标准时间维度，guest embedding 通常不应把它作为主要入口。",
      "source": "frontend query/constants.ts + processExtraFormData.ts",
      "status": "低相关，不建议作为 Gauge guest embedding 的主要动态入口"
    }
  ],
  "minimal_extra_form_data_template": {
    "filters": [
      {
        "col": "name",
        "op": "IN",
