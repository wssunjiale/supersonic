  "notes": [
    "world_map 仍然是 legacy 图，前端 metadata 明确声明 `useLegacyApi=true`，真实请求路径是 `/superset/explore_json/`。",
    "`/superset/explore_json/` 路径会读取原始 `form_data`，补 `datasource`，然后执行 `convert_legacy_filters_into_adhoc(form_data)` 与 `merge_extra_filters(form_data)`。",
    "当前源码里 `Guest user cannot modify chart payload` 这条错误只在 `security/manager.py::raise_for_access(query_context=...)` 分支触发，核心比较器是 `query_context_modified()`。",
    "legacy `/superset/explore_json/` 的权限检查会走 `views/utils.py::check_datasource_perms()` -> `get_viz()` -> `viz.raise_for_access()` -> `security/manager.py::raise_for_access(viz=self)`。当前 `viz` 分支会校验 `dashboardId` / `slice_id` / datasource 绑定，但没有 `query_context_modified()` 那种 columns / metrics / orderby 子集比较器。",
    "即便如此，最稳妥的策略仍然是根层 form_data 直接复制保存态图表，只把动态过滤条件放进 `extra_form_data`。",
    "`entity`、`country_fieldtype`、`metric`、`secondary_metric`、`row_limit`、`sort_by_metric` 会改变底层查询或返回 shape；`show_bubbles`、`max_bubble_size`、`color_by`、颜色格式字段会改变地图定义；这些都不适合在 guest embedding 请求里临时重构。"
  ],
  "security_enforcement": {
    "frontend_request_mode": "legacy explore_json",
    "frontend_request_endpoint": "/superset/explore_json/",
    "frontend_request_payload": {
      "form_data": "<raw form_data>"
    },
    "backend_normalization_steps": [
      "convert_legacy_filters_into_adhoc(form_data)",
      "merge_extra_filters(form_data)"
    ],
    "verified_guest_payload_guard": {
      "chart_data_api": "security/manager.py::query_context_modified",
      "chart_data_api_error": "Guest user cannot modify chart payload",
      "legacy_explore_json_api": "`check_datasource_perms()` 会构造 viz 并调用 `raise_for_access(viz=self)`；该分支校验 datasource / dashboard / slice 绑定，但没有 `query_context_modified()` 那种 query subset guard",
      "confidence": "high"
    },
    "guest_access_binding_fields": [
      "dashboardId",
      "slice_id"
    ],
    "query_critical_root_fields": [
      "datasource",
      "viz_type",
      "entity",
      "country_fieldtype",
      "metric",
      "secondary_metric",
      "adhoc_filters",
      "row_limit",
      "sort_by_metric"
    ],
    "recommended_strategy": "复制保存态 chart form_data 作为 base，仅通过 extra_form_data 追加 filters / adhoc_filters；不要在 embedding 请求里重构 world_map 的 root 查询字段和地图定义字段。"
  },
  "safe_base_rule": {
    "description": "第三方 embedding 请求中的根层 form_data，应当从已保存的 World Map 图表直接复制，不要自行重构。",
    "must_be_copied_from_saved_chart": [
      "slice_id",
      "dashboardId",
      "datasource",
      "viz_type",
      "entity",
      "country_fieldtype",
      "metric",
      "secondary_metric",
      "adhoc_filters",
      "row_limit",
      "sort_by_metric",
      "show_bubbles",
      "max_bubble_size",
      "color_picker",
      "color_by",
      "linear_color_scheme",
      "color_scheme",
      "y_axis_format",
      "currency_format",
      "all other saved chart-definition fields"
    ],
    "why": [
      "world_map 没有专属前端 buildQuery，前端直接把 root form_data 发给 `/superset/explore_json/`。",
      "`WorldMapViz.query_obj()` 会直接消费 root `entity`、`metric`、`secondary_metric`、`row_limit`、`sort_by_metric`。",
      "`WorldMapViz.get_data()` 会直接消费 `country_fieldtype` 与 `secondary_metric`，并决定是否生成 `m2`。",
      "`transformProps()` 与 `WorldMap.js` 会直接消费 `show_bubbles`、`max_bubble_size`、`color_by`、颜色和格式字段；这些都会改变地图定义。",
      "`WorldMap.js` 的交互式 cross-filter 也是通过 `extraFormData.filters` 追加过滤，而不是重写根层查询字段。"
    ]
  },
  "safe_embedding_form_data_template": {
    "description": "这是 world_map embedding 下的保守安全写法。根层以保存态图表为 base，仅改 extra_form_data。",
    "template": {
      "slice_id": "<saved_chart_id>",
      "dashboardId": "<dashboard_id>",
      "datasource": "<copied_from_saved_chart>",
      "viz_type": "world_map",
      "entity": "<copied_from_saved_chart>",
      "country_fieldtype": "<copied_from_saved_chart>",
      "metric": "<copied_from_saved_chart>",
      "secondary_metric": "<copied_from_saved_chart>",
      "adhoc_filters": "<copied_from_saved_chart>",
      "row_limit": "<copied_from_saved_chart>",
      "sort_by_metric": "<copied_from_saved_chart>",
      "show_bubbles": "<copied_from_saved_chart>",
      "max_bubble_size": "<copied_from_saved_chart>",
      "color_picker": "<copied_from_saved_chart>",
      "color_by": "<copied_from_saved_chart>",
      "linear_color_scheme": "<copied_from_saved_chart>",
      "color_scheme": "<copied_from_saved_chart>",
      "y_axis_format": "<copied_from_saved_chart>",
      "currency_format": "<copied_from_saved_chart>",
      "extra_form_data": {
        "filters": [
          {
            "col": "country_code",
            "op": "IN",
            "val": [
              "CN"
            ]
          }
        ],
        "adhoc_filters": [
          {
            "expressionType": "SIMPLE",
            "clause": "WHERE",
            "subject": "year",
            "operator": "==",
            "comparator": 2024
          }
        ],
        "custom_form_data": {}
      }
    }
  },
  "preferred_dynamic_container": {
    "field_name": "extra_form_data",
    "description": "legacy `/superset/explore_json/` 路径同样会在 `merge_extra_filters()` -> `merge_extra_form_data()` 中消费它。",
    "append_keys": [
      "adhoc_filters",
      "filters",
      "interactive_groupby",
      "interactive_highlight",
      "interactive_drilldown",
      "custom_form_data"
    ],
    "override_keys_backend_high_confidence": [],
    "notes": "对 world_map 来说，`filters` 与 `adhoc_filters` 是最稳妥的动态入口；不要在 guest 请求里改国家编码格式、主指标、bubble 指标或颜色策略。"
  },
  "extra_form_data_field_schema": [
    {
      "field_name": "filters",
      "data_type": "array[QueryObjectFilterClause]",
      "behavior": "append",
      "safe_for_world_map_legacy": true,
      "recommended": true,
      "sample_data": [
        {
          "col": "country_code",
          "op": "IN",
          "val": [
            "CN"
          ]
        }
      ],
      "effect": "追加 simple filters；这也是 WorldMap.js 点击国家后生成 cross-filter 的主要形态。",
      "source": "superset/constants.py + superset/utils/core.py + WorldMap.js"
    },
    {
      "field_name": "adhoc_filters",
      "data_type": "array[AdhocFilter]",
      "behavior": "append",
      "safe_for_world_map_legacy": true,
      "recommended": true,
      "sample_data": [
        {
          "expressionType": "SIMPLE",
          "clause": "WHERE",
          "subject": "year",
          "operator": "==",
          "comparator": 2024
        }
      ],
      "effect": "追加 adhoc filters；后端会标记为 extra 并并入查询。",
      "source": "superset/constants.py + superset/utils/core.py"
    },
    {
      "field_name": "custom_form_data",
      "data_type": "object",
      "behavior": "append",
      "safe_for_world_map_legacy": true,
      "recommended": false,
      "sample_data": {},
      "effect": "传递非标准附加数据；world_map 默认不直接消费它。",
      "source": "QueryFormData.ts + superset/constants.py"
    }
  ],
  "not_recommended_guest_mutations": [
