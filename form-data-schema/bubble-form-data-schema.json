  "api_usage_guidance": {
    "high_confidence_required_fields": [
      "datasource",
      "viz_type",
      "entity",
      "x",
      "y",
      "size"
    ],
    "recommended_always_set": [
      "adhoc_filters",
      "max_bubble_size",
      "color_scheme",
      "show_legend",
      "x_axis_format",
      "y_axis_format"
    ],
    "api_field_examples": [
      "series",
      "entity",
      "x",
      "y",
      "size",
      "limit",
      "max_bubble_size",
      "x_axis_format",
      "y_axis_bounds"
    ],
    "avoid_confusion": [
      "不要把 legacy bubble 的 row limit 写成 `row_limit`；当前正式入口字段是 `limit`。",
      "不要把运行时别名 `maxBubbleSize`、`showLegend`、`xAxisFormat`、`yAxisBounds` 当成 API root 键；保存态仍应使用 snake_case 字段。",
      "不要把 `x_axis_format` 当成时间格式控件；legacy bubble 这里是数值 D3 format。",
      "如果 `series` 为空，不需要额外补默认值；后端会回退成 `entity`。",
      "确保 `x/y/size` 三个指标在最终标签上互不相同，否则 BubbleViz 会拒绝查询。"
    ]
