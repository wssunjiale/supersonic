  "conditional_blocks": {
    "dimension_grouping": {
      "condition": "需要按维度拆分多条对比序列时",
      "fields": {
        "groupby": [
          "region"
        ],
        "limit": 10,
        "timeseries_limit_metric": {
          "expressionType": "SIMPLE",
          "column": {
            "column_name": "sales"
          },
          "aggregate": "SUM",
          "label": "SUM(sales)"
        },
        "order_desc": true
      }
    },
    "time_shift_overlay": {
      "condition": "需要把过去周期叠加成额外折线时",
      "fields": {
        "time_compare": [
          "1 year"
        ],
        "comparison_type": "values",
        "time_range": "2025-01-01 : 2025-01-31"
      }
    },
    "time_shift_difference": {
      "condition": "需要显示当前序列与 time shift 的差值、百分比变化或比值时",
      "fields": {
        "time_compare": [
          "1 year"
        ],
        "comparison_type": "percentage",
        "y_axis_format": ".1%"
      }
    },
    "rolling_window": {
      "condition": "需要先做 rolling window 再绘图时",
      "fields": {
        "rolling_type": "mean",
        "rolling_periods": 7,
        "min_periods": 7
      }
    },
    "resample": {
      "condition": "需要先按固定频率重采样再比较时",
      "fields": {
        "resample_rule": "1D",
        "resample_method": "mean"
      }
    },
    "contribution_view": {
      "condition": "需要把每个时间点的序列值转换成总量占比时",
      "fields": {
        "contribution": true,
        "y_axis_format": ".1%"
      }
    },
    "annotations": {
      "condition": "需要在 compare 图上叠加事件、区间或时间序列注释层时",
      "fields": {
        "annotation_layers": [
          {
            "name": "release-window"
          }
        ]
      }
    },
    "axis_formatting": {
      "condition": "需要显式配置坐标轴标题、时间格式、数值格式和边界时",
      "fields": {
        "x_axis_label": "Order Date",
        "x_axis_format": "smart_date",
        "y_axis_label": "Percent Change",
        "y_axis_format": ".1%",
        "y_axis_bounds": [
          -1,
          1
        ]
      }
    },
    "legacy_datasource_granularity": {
      "condition": "如果底层仍是 legacy datasource 且需要显式传旧时间粒度字段时",
      "fields": {
        "granularity": "P1D"
      }
    }
  },
