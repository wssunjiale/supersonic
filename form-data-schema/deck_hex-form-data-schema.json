    "api_field_examples": [
      "spatial",
      "size",
      "filter_nulls",
      "mapbox_style",
      "color_scheme_type",
      "color_breakpoints",
      "viewport",
      "grid_size",
      "js_agg_function"
    ],
    "avoid_confusion": [
      "不要把 deck_hex 当成标准 chart data API 图表去套 `/api/v1/chart/data` 的 `query_context` 模板；当前图真实入口是 legacy `/superset/explore_json/`。",
      "不要把 `size` 误写成 `metric` 或 `metrics`；当前图的正式指标字段名就是 `size`。",
      "不要把 `deafult_breakpoint_color` 更正成自认为更合理的拼写；源码正式字段名就是这个拼写。",
      "`spatial` 不是单个字符串列名，而是一个对象。根据你的空间数据编码方式，必须传 `latlong` / `delimited` / `geohash` 三种形状之一。",
      "`viewport` 是正式保存态字段，但 `width`/`height` 由运行时补入，不要把这两个字段写回 root form_data。"
    ]
  }
