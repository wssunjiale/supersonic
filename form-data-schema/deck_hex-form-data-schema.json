    "viz_type": {
      "data_type": "string",
      "required": true,
      "fixed_value": "deck_hex",
      "source": "Hex/index.ts + VizType.DeckHex"
    },
    "spatial": {
      "data_type": "object",
      "required": true,
      "sample_data": {
        "type": "latlong",
        "lonCol": "LON",
        "latCol": "LAT"
      },
      "source": "Hex Query section + SpatialControl validator + BaseDeckGLViz.query_obj()",
      "notes": "高置信必填。没有它，后端无法展开空间列并构造 `position`。"
    }
  },
