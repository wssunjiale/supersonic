  "conditional_blocks": {
    "delimited_spatial_column": {
      "condition": "空间字段存储在单列经纬度字符串中时",
      "fields": {
        "spatial": {
          "type": "delimited",
          "lonlatCol": "LONLAT",
          "delimiter": ",",
          "reverseCheckbox": false
        }
      }
    },
    "geohash_spatial_column": {
      "condition": "空间字段存储为 geohash 时",
      "fields": {
        "spatial": {
          "type": "geohash",
          "geohashCol": "geohash",
          "reverseCheckbox": false
        }
      }
    },
    "count_points_instead_of_metric": {
      "condition": "只想按点数量聚合 hex cell，而不想显式传指标时",
      "fields": {
        "size": null,
        "js_agg_function": "sum"
      },
      "notes": "此时每个点的 `weight` 在后端会回退为 1。"
    },
    "fixed_color_mode": {
      "condition": "需要所有 hex cell 使用同一固定色时",
      "fields": {
        "color_scheme_type": "fixed_color",
        "color_picker": {
          "r": 0,
          "g": 122,
          "b": 135,
          "a": 1
        }
      }
    },
    "categorical_palette_mode": {
      "condition": "需要使用调色板颜色范围时",
      "fields": {
        "color_scheme_type": "categorical_palette",
        "color_scheme": "SUPERSET_DEFAULT"
      }
    },
    "breakpoint_color_mode": {
      "condition": "需要手工定义聚合值区间对应颜色时",
      "fields": {
        "color_scheme_type": "color_breakpoints",
        "deafult_breakpoint_color": {
          "r": 158,
          "g": 158,
          "b": 158,
          "a": 1
        },
        "color_breakpoints": [
          {
            "minValue": 0,
            "maxValue": 100,
            "color": {
              "r": 255,
              "g": 0,
              "b": 0,
              "a": 1
            }
          }
        ]
      }
    },
    "custom_js": {
      "condition": "需要自定义数据加工、tooltip 或点击跳转行为时",
      "fields": {
        "js_columns": [
          "city"
        ],
        "js_data_mutator": "data => data",
        "js_tooltip": "o => `<div>${o.object.elevationValue}</div>`",
        "js_onclick_href": "o => `https://example.com/${o.coordinate[0]},${o.coordinate[1]}`"
      }
    }
  },
