    "D:/vsx/sources/superset-6.0.0/superset-frontend/plugins/legacy-plugin-chart-rose/src/transformProps.js",
    "D:/vsx/sources/superset-6.0.0/superset-frontend/plugins/legacy-plugin-chart-rose/src/Rose.js",
    "D:/vsx/sources/superset-6.0.0/superset-frontend/packages/superset-ui-chart-controls/src/sections/sections.tsx",
