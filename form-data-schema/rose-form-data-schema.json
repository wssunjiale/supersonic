{
  "viz_type": "rose",
  "display_name": "Nightingale Rose Chart",
  "purpose": "用于调用 API 创建或保存 Nightingale Rose Chart 时填写的 form_data 模板",
  "base_schema_file": "D:/vsx/metrics/supersonic/form-data-schema/rose-schema.json",
