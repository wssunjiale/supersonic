  "conditional_blocks": {
    "multiple_gauges": {
      "condition": "需要按维度输出多个 gauge 项时",
      "fields": {
        "groupby": [
          "name"
        ],
        "row_limit": 10
      },
      "notes": "`groupby` 有值时，`transformProps.ts` 会为每条结果生成一个 GaugeDataItem，并通过 `allEventHandlers` 支持点击筛选。"
    },
    "metric_sorting": {
      "condition": "需要让多个 gauge 按指标值降序排列时",
      "fields": {
        "sort_by_metric": true
      },
      "notes": "这会让 `buildQuery.ts` 额外写入 `orderby=[[metric,false]]`。"
    },
    "fixed_axis_range": {
      "condition": "需要固定 gauge 量程时",
      "fields": {
        "min_val": 0,
        "max_val": 100
      },
      "notes": "若不显式提供，运行时会按数据自动推导两倍范围。"
    },
    "interval_coloring": {
      "condition": "需要按区间着色 gauge 轴线时",
      "fields": {
        "intervals": "60,100",
        "interval_color_indices": "1,2"
      },
      "notes": "`intervals` 和 `interval_color_indices` 都必须是逗号分隔的数字文本。"
    },
    "separate_multiple_rings": {
      "condition": "需要让多个 gauge 进度环分离显示时",
      "fields": {
        "overlap": false,
        "show_progress": true
      },
      "notes": "`overlap=false` 会让轴线宽度按 `data.length * fontSize` 扩大，形成分离多环。"
    },
    "append_unit_text": {
      "condition": "需要为数值追加单位时",
      "fields": {
        "value_formatter": "{value}%"
      },
      "notes": "运行时通过字符串替换 `{value}` 拼接格式化后的数值。"
    }
  },
  "runtime_only_or_non_template_fields": {
    "runtime_camel_case_aliases": [
      {
        "field_name": "rowLimit / minVal / maxVal / startAngle / endAngle / colorScheme / fontSize / numberFormat / currencyFormat / valueFormatter / showPointer / showAxisTick / showSplitLine / splitNumber / showProgress / roundCap / intervalColorIndices",
        "reason": "这些是运行时 camelCase 别名，不是 API root form_data 的 canonical 键名。"
      }
    ],
    "query_context_generated_fields": [
      {
        "field_name": "query_context.queries[*].metrics",
        "reason": "由 root `metric` 经标准 query builder 生成。"
      },
      {
        "field_name": "query_context.queries[*].columns",
        "reason": "由 root `groupby` 经标准 query builder 生成。"
      },
      {
        "field_name": "query_context.queries[*].orderby",
        "reason": "只在 `sort_by_metric=true` 时由 `Gauge/buildQuery.ts` 注入。"
      }
    ],
    "hidden_runtime_defaults_not_template_fields": [
      {
        "field_name": "showLegend / legendType / legendOrientation / legendMargin",
        "reason": "它们出现在 `Gauge/types.ts::DEFAULT_FORM_DATA`，但当前 Gauge controlPanel 与 transformProps 都没有正式使用。"
      }
    ],
    "viz_switch_only": [
      {
        "field_name": "formDataOverrides(metric/groupby remap)",
        "reason": "只在 standardizedFormData.transform() 切换图表时触发，不是常规 Gauge API 创建模板字段。"
      }
    ]
  },
  "api_usage_guidance": {
    "high_confidence_required_fields": [
      "datasource",
      "viz_type",
      "metric"
    ],
    "recommended_always_set": [
      "groupby",
      "adhoc_filters",
      "row_limit",
      "min_val",
      "max_val",
      "color_scheme",
      "font_size",
      "number_format",
      "value_formatter",
      "show_progress"
    ],
    "mixed_case_examples": [
      "row_limit",
      "min_val",
      "max_val",
      "start_angle",
      "end_angle",
      "font_size",
      "show_axis_tick",
      "show_split_line",
      "split_number",
      "show_progress",
      "round_cap",
      "interval_color_indices"
    ],
    "avoid_confusion": [
      "不要把 `rowLimit`、`minVal`、`startAngle`、`intervalColorIndices` 当成 API root 键名。",
      "`intervals` 和 `interval_color_indices` 都是文本输入，不是数组。",
      "`sort_by_metric` 只是决定是否注入 `orderby`，不是独立排序字段集合。",
      "Gauge 当前没有正式 legend 配置；不要把 `show_legend` 一类字段主动塞进 canonical 创建模板。"
    ]
  }
}
