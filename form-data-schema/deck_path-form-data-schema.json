  "api_usage_guidance": {
    "high_confidence_required_fields": [
      "datasource",
      "viz_type",
      "line_column",
      "line_type",
      "color_picker"
    ],
    "recommended_always_set": [
      "adhoc_filters",
      "filter_nulls",
      "row_limit",
      "mapbox_style",
      "viewport",
      "line_width",
      "line_width_unit",
      "reverse_long_lat",
      "autozoom"
    ],
    "api_field_examples": [
      "line_column",
      "line_type",
      "color_picker",
      "line_width",
      "line_width_unit",
      "mapbox_style",
      "viewport"
    ],
    "avoid_confusion": [
      "不要把 deck_path 当成标准 chart data API 图表去套 `/api/v1/chart/data` 的 `query_context` 模板；当前图真实入口是 legacy `/superset/explore_json/`。",
      "`line_column` 这里传的是列名，不是路径数组本身。",
      "canonical 模板里的 `line_type` 只应写 `polyline` 或 `json`；不要因为后端仍保留 `geohash` 反序列化器就把它当成当前 UI 正式支持值。",
      "当前图没有正式 metric 字段，不要把 `size`、`metric`、`metrics` 当成常规必填去构造。",
      "`color_picker` 不是可有可无的装饰字段；运行时会直接读取它。",
      "交互筛选应优先写进 `extra_form_data.filters`，其中 `col` 是 SQL expression 对象，不是普通列名。"
    ]
  }
}
