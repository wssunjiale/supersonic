          "expressionType": "SIMPLE",
          "column": {
            "column_name": "<metric_column>"
          },
          "aggregate": "SUM",
          "label": "SUM(<metric_column>)"
        },
        "order_desc": true,
        "group_others_when_limit_reached": false
      }
    },
    "area_fill": {
      "condition": "需要把阶梯线渲染为带面积填充的 step chart 时",
      "fields": {
        "area": true,
        "opacity": 0.2
      }
