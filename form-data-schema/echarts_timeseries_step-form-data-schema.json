  "conditional_blocks": {
    "multi_series": {
      "condition": "需要按维度拆分多条阶梯线时",
      "fields": {
        "groupby": [
          "<dimension_column>"
        ]
      }
    },
    "step_type": {
      "condition": "需要控制阶梯拐点位置时",
      "fields": {
        "seriesType": "middle"
      },
      "enum_values": [
        "start",
        "middle",
        "end"
      ]
    },
    "sort_x_axis_series": {
      "condition": "需要按名称、求和、均值等规则对 x 轴系列排序时",
      "fields": {
        "x_axis_sort": "<metric_label_or_sort_choice>",
        "x_axis_sort_asc": true
      }
    },
    "limit_series": {
      "condition": "需要限制 series 数量时",
