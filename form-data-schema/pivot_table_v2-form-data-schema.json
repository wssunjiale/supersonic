  "conditional_blocks": {
    "temporal_bucketization": {
      "condition": "rows/columns 中使用 temporal 列，且希望按时间粒度分桶时",
      "fields": {
        "groupbyColumns": [
          "order_date"
        ],
        "time_grain_sqla": "P1D",
        "temporal_columns_lookup": {
          "order_date": true
        }
      },
      "notes": "`buildQuery.ts` 依赖 `time_grain_sqla + temporal_columns_lookup` 把物理时间列改写成带 `timeGrain` 的 AdhocColumn。"
    },
    "top_series_sorting": {
      "condition": "需要按指定指标截断 top series / top cells 时",
      "fields": {
        "series_limit": 25,
        "series_limit_metric": {
          "expressionType": "SIMPLE",
          "column": {
            "column_name": "sales"
          },
          "aggregate": "SUM",
          "label": "SUM(sales)"
        },
        "order_desc": true
      },
      "notes": "如果 `series_limit_metric` 为空，`buildQuery.ts` 会退回使用 `metrics[0]` 生成 `orderby`。"
    },
    "metrics_on_rows": {
      "condition": "需要把指标作为行级顶层分组时",
      "fields": {
        "metricsLayout": "ROWS"
      }
    },
    "totals_and_subtotals": {
      "condition": "需要显示总计与小计时",
      "fields": {
        "rowTotals": true,
        "rowSubTotals": true,
        "colTotals": true,
        "colSubTotals": true,
        "rowSubtotalPosition": true,
        "colSubtotalPosition": false
      }
    },
    "conditional_coloring": {
      "condition": "需要按指标值给单元格着色时",
      "fields": {
        "conditional_formatting": [
          {
            "column": "SUM(sales)",
            "operator": ">",
            "targetValue": 1000,
            "colorScheme": "rgba(0, 122, 135, 1)"
          }
        ]
      }
    },
    "html_rendering": {
      "condition": "单元格值包含 `<a>` 等 HTML，且希望按 HTML 渲染时",
      "fields": {
        "allow_render_html": true
      }
    }
  },
