  "notes": [
    "World Map 是 legacy 图。前端 metadata 明确声明 `useLegacyApi=true`，真实请求路径是 `/superset/explore_json/`。",
    "`/superset/explore_json/` 会读取原始 `form_data`，然后在后端 `BaseViz.process_query_filters()` 中执行 `convert_legacy_filters_into_adhoc(form_data)` 与 `merge_extra_filters(form_data)`。",
    "World Map 没有前端 buildQuery；真正的查询组装在后端 `WorldMapViz.query_obj()` 和 `BaseViz.query_obj()` 内完成。",
    "`entity` 和 `metric` 是新建模板的核心必填字段。`secondary_metric` 是气泡大小的条件必需字段：只有在 `show_bubbles=true` 时才强烈建议提供。",
    "`country_fieldtype` 决定实体列采用哪种国家编码标准；后端会把原始值映射成统一的 `cca3` 国家代码后再给前端地图渲染。",
    "World Map 的前端 runtime 看到的是 camelCase 形态，如 `countryFieldtype`、`showBubbles`、`maxBubbleSize`、`colorBy`；API 入参仍应使用原始 snake_case 键。",
    "`sort_by_metric` 只会按主 metric 排序，不会改成按 `secondary_metric` 排序。"
  ],
  "naming_and_pipeline": {
    "control_to_api_form_data": "getFormDataFromControls() 直接把 controls[name].value 写成 form_data[name]。",
    "frontend_request_mode": "legacy explore_json",
    "api_form_data_to_backend_query": "前端把原始 form_data 发给 `/superset/explore_json/`；后端 BaseViz / WorldMapViz 直接读取这些 root 键。",
    "api_form_data_to_runtime_form_data": "legacy 插件 transformProps 会把 snake_case form_data 转成 camelCase runtime props。",
    "backend_metric_collection": "BaseViz.process_metrics() 会把 `metric` 与 `secondary_metric` 一并加入 metrics 列表。"
  },
  "global_required_fields": {
    "datasource": {
      "data_type": "string",
      "required": true,
      "sample_data": "<dataset_id>__table",
      "source": "datasourceAndVizType section"
    },
    "viz_type": {
      "data_type": "string",
      "required": true,
      "fixed_value": "world_map",
      "source": "datasourceAndVizType section"
    },
    "entity": {
      "data_type": "string | object",
      "required": true,
      "sample_data": "country_code",
      "source": "World Map Query section + shared entity validator"
    },
    "metric": {
      "data_type": "string | object",
      "required": true,
      "sample_data": {
        "expressionType": "SIMPLE",
        "column": {
          "column_name": "value"
        },
        "aggregate": "SUM",
        "label": "SUM(value)"
      },
      "source": "World Map Query section + shared metric validator"
    }
  },
  "global_optional_fields": {
    "country_fieldtype": {
      "data_type": "string",
      "required": false,
      "sample_data": "cca2",
      "source": "World Map Query section"
    },
    "secondary_metric": {
      "data_type": "string | object | null",
      "required": false,
      "sample_data": {
        "expressionType": "SIMPLE",
        "column": {
          "column_name": "population"
        },
        "aggregate": "SUM",
        "label": "SUM(population)"
      },
      "source": "World Map Options section",
      "notes": "这不是经验判断。`WorldMapViz.get_data()` 只有在它非空时才会生成 `m2`，而 `WorldMap.js` 的 bubble 半径直接依赖 `d.m2`。因此 `show_bubbles=true` 时应把它视为条件必需字段。"
    },
    "adhoc_filters": {
      "data_type": "array[object]",
      "required": false,
      "sample_data": [],
      "source": "World Map Query section"
    },
    "row_limit": {
      "data_type": "integer | string",
      "required": false,
      "sample_data": 10000,
      "source": "World Map Query section"
    },
    "sort_by_metric": {
      "data_type": "boolean",
      "required": false,
      "sample_data": false,
      "source": "World Map Query section"
    },
    "show_bubbles": {
      "data_type": "boolean",
      "required": false,
      "sample_data": false,
      "source": "World Map Options section"
    },
    "max_bubble_size": {
      "data_type": "string | integer",
      "required": false,
      "sample_data": "25",
      "source": "World Map Options section"
    },
    "color_picker": {
      "data_type": "object",
      "required": false,
      "sample_data": {
        "r": 0,
        "g": 122,
        "b": 135,
        "a": 1
      },
      "source": "World Map Options section"
    },
    "color_by": {
      "data_type": "string",
      "required": false,
      "sample_data": "metric",
      "source": "World Map Options section"
    },
    "linear_color_scheme": {
      "data_type": "string",
      "required": false,
      "sample_data": "<sequential_scheme_key>",
      "source": "World Map Options section"
    },
    "color_scheme": {
      "data_type": "string",
      "required": false,
      "sample_data": "bnbColors",
      "source": "World Map Options section"
    },
    "y_axis_format": {
      "data_type": "string",
