  "recommended_form_data_template": {
    "datasource": "<dataset_id>__table",
    "viz_type": "world_map",
    "entity": "country_code",
    "country_fieldtype": "cca2",
    "metric": {
      "expressionType": "SIMPLE",
      "column": {
        "column_name": "value"
      },
      "aggregate": "SUM",
      "label": "SUM(value)"
    },
    "adhoc_filters": [],
    "row_limit": 10000,
    "sort_by_metric": false,
    "show_bubbles": false,
    "max_bubble_size": "25",
    "color_picker": {
      "r": 0,
      "g": 122,
      "b": 135,
      "a": 1
    },
    "color_by": "metric",
    "linear_color_scheme": "<sequential_scheme_key>",
    "color_scheme": "bnbColors",
    "y_axis_format": "SMART_NUMBER",
    "currency_format": null
  },
  "conditional_blocks": {
    "bubble_overlay_mode": {
      "condition": "需要在国家底图上叠加 bubbles 时",
      "fields": {
        "show_bubbles": true,
        "secondary_metric": {
          "expressionType": "SIMPLE",
          "column": {
            "column_name": "population"
          },
          "aggregate": "SUM",
          "label": "SUM(population)"
        },
        "max_bubble_size": "25",
        "color_picker": {
          "r": 0,
          "g": 122,
          "b": 135,
          "a": 1
        }
      },
      "notes": "如果缺少 `secondary_metric`，后端不会生成 `m2`；而 `WorldMap.js` 会直接用 `d.m2` 计算 bubble radius。"
    },
    "same_metric_for_fill_and_bubble": {
      "condition": "需要用同一个指标同时控制底图着色与 bubble 大小时",
      "fields": {
        "secondary_metric": {
          "expressionType": "SIMPLE",
          "column": {
            "column_name": "value"
          },
          "aggregate": "SUM",
          "label": "SUM(value)"
        }
      },
      "notes": "WorldMapViz.get_data() 会在 `metric == secondary_metric` 时把 `m2 = m1`。"
    },
    "country_palette_mode": {
      "condition": "需要按国家分类色板着色，而不是按主指标渐变色着色时",
      "fields": {
        "color_by": "country",
        "color_scheme": "bnbColors"
      }
    },
    "metric_palette_mode": {
      "condition": "需要按主指标连续色带着色时",
      "fields": {
        "color_by": "metric",
        "linear_color_scheme": "<sequential_scheme_key>"
      }
    }
  },
  "runtime_only_or_non_template_fields": {
    "runtime_aliases_only": [
      {
        "field_name": "countryFieldtype/showBubbles/maxBubbleSize/linearColorScheme/colorPicker/colorBy/colorScheme/sliceId/yAxisFormat/currencyFormat",
        "reason": "这些是 legacy transformProps 产出的 runtime camelCase 形态；API 调用时应使用原始 snake_case 键。"
      }
    ],
    "backend_generated_query_fields": [
      {
        "field_name": "groupby",
        "reason": "WorldMapViz.query_obj() 会把它强制生成为 `[entity]`。"
      },
      {
        "field_name": "orderby",
        "reason": "只有 `sort_by_metric=true` 时，WorldMapViz.query_obj() 才会按主 metric 生成降序排序。"
      }
    ],
    "source_inconsistencies": [
      {
        "field_name": "entity",
        "reason": "controlOverride 的描述写的是 `3 letter code of the country`，但 `country_fieldtype` 实际支持 `name/cioc/cca2/cca3` 四种输入格式。"
      }
    ]
  }
}
