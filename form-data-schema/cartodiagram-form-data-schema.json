      },
      {
        "field_name": "chartConfigs",
        "reason": "这是 transformProps 根据查询结果和被引用图表 transformProps 计算出的 GeoJSON FeatureCollection，不是 root form_data 字段。"
      },
      {
        "field_name": "chartVizType",
        "reason": "这是从 `selected_chart.viz_type` 派生出的运行时字段，不是 root form_data 字段。"
      }
    ],
    "query_result_only_fields": [
      {
        "field_name": "queriesData[0].data",
        "reason": "这是 chart data API 返回的底层结果集；Cartodiagram 会再按几何位置拆分它。"
      },
      {
        "field_name": "queriesData[0].label_map",
        "reason": "仅在被引用图表包含 `x_axis` 等时序语义时，运行时会用它拆出 GeoJSON 列和其余 series label。"
      }
    ]
  },
  "api_usage_guidance": {
    "high_confidence_required_fields": [
      "datasource",
      "viz_type",
      "selected_chart",
      "geom_column"
    ],
    "recommended_always_set": [
      "map_view",
      "layer_configs",
      "chart_background_color",
      "chart_background_border_radius",
      "chart_size"
    ],
    "avoid_confusion": [
      "不要把 `selected_chart` 写成对象；源码要求它是 JSON 字符串。",
      "不要把 `selected_chart.params` 写成对象；源码要求它仍然是字符串。",
      "不要把 runtime camelCase 字段名写回 root form_data。",
      "不要忘记让 root `datasource` 与 `selected_chart.params.datasource` 保持同一个 dataset，否则 UI 约束和运行时语义会不一致。",
      "Cartodiagram 自己不定义 metrics/groupby 语义；真正的查询字段来自被引用图表。"
    ]
  }
