  "conditional_blocks": {
    "custom_map_extent": {
      "condition": "需要固定地图初始范围，而不是自动 fit data 时",
      "fields": {
        "map_view": {
          "mode": "CUSTOM",
          "zoom": 6,
          "latitude": 47.3769,
          "longitude": 8.5417,
          "fixedZoom": 6,
          "fixedLatitude": 47.3769,
          "fixedLongitude": 8.5417
        }
      }
    },
    "wms_layer": {
      "condition": "需要叠加 WMS 图层时",
      "fields": {
        "layer_configs": [
          {
            "type": "WMS",
            "version": "1.3.0",
            "title": "Administrative Boundaries",
            "url": "https://example.com/geoserver/wms",
            "layersParam": "workspace:admin_boundaries",
            "attribution": "© Example"
          }
        ]
      }
    },
    "wfs_layer": {
      "condition": "需要叠加可样式化的 WFS 图层时",
      "fields": {
        "layer_configs": [
          {
            "type": "WFS",
            "version": "2.0.2",
            "title": "Road Network",
            "url": "https://example.com/geoserver/wfs",
            "typeName": "workspace:roads",
            "maxFeatures": 10000,
            "style": {
              "name": "Default Style",
              "rules": [
                {
                  "name": "Default Rule",
                  "symbolizers": [
                    {
                      "kind": "Line",
                      "color": "#000000",
                      "width": 2
                    }
                  ]
                }
              ]
            }
          }
        ]
      }
    },
    "xyz_layer": {
      "condition": "需要叠加 XYZ 瓦片底图时",
      "fields": {
        "layer_configs": [
          {
            "type": "XYZ",
            "title": "OpenStreetMap",
            "url": "https://tile.openstreetmap.org/{z}/{x}/{y}.png",
            "attribution": "© OpenStreetMap contributors"
          }
        ]
      }
    },
    "linear_chart_size": {
      "condition": "需要按 zoom 线性放大小图时",
      "fields": {
        "chart_size": {
          "type": "LINEAR",
          "configs": {
            "zoom": 6,
            "width": 100,
            "height": 100,
            "slope": 30
          },
          "values": "<由 zoomUtil.computeConfigValues() 生成 0..28 的 width/height 映射>"
        }
      }
    },
    "exp_chart_size": {
      "condition": "需要按 zoom 指数放大小图时",
      "fields": {
        "chart_size": {
          "type": "EXP",
          "configs": {
            "zoom": 6,
            "width": 100,
            "height": 100,
            "exponent": 2
          },
          "values": "<由 zoomUtil.computeConfigValues() 生成 0..28 的 width/height 映射>"
        }
      }
    },
    "dashboard_filter_passthrough": {
      "condition": "需要把 dashboard/native filters 透传给被引用图表时",
      "fields": {
        "extra_form_data": {
          "filters": [
            {
              "col": "region",
              "op": "IN",
              "val": [
                "East"
              ]
            }
          ]
        }
      }
    }
  },
