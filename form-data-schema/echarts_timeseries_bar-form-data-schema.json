  "conditional_blocks": {
    "multi_series": {
      "condition": "需要按维度拆分多组 bar series 时",
      "fields": {
        "groupby": [
          "<dimension_column>"
        ]
      }
    },
    "sort_x_axis_series": {
      "condition": "需要按名称、求和、均值等规则对基础轴系列排序时",
