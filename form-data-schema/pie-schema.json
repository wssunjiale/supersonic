  "notes": [
    "Pie Chart 是 ECharts 图，走 buildQueryContext/query context，而不是 legacy `/superset/explore_json/`。",
    "`metric` 是单值根字段，但 `extractQueryFields()` 会把 `metric` 别名映射成 query `metrics`；`groupby` 会映射成 query `columns`。",
    "`buildQuery.ts` 在基础查询后固定追加 `contribution` post_processing，并把指标贡献列重命名成 `Contribution(<metricLabel>)`；`transformProps.ts` 的 `threshold_for_other` 逻辑依赖这列。",
    "`controlOverrides.row_limit.default=100` 且 `formDataOverrides` 会把任何 `row_limit >= 100` 的值截成 `100`，因此当前图的高置信行数上限就是 100。",
    "`controlOverrides.series` 虽然设置了 `validateNonEmpty`，但当前 controlPanel 并没有暴露 `series` 控件；API form_data 不应额外补一个 `series`。",
    "`transformProps.ts` 消费的是 runtime camelCase 别名，但真正 API form_data 仍应使用 control name 原样键名，例如 `date_format`、`number_format`、`show_labels`、`threshold_for_other`。"
  ],
  "metadata_summary": {
    "description": "Classic proportional chart for part-to-whole comparison. Supports ordinary pie, donut, and Nightingale rose modes.",
    "category": "Part of a Whole",
    "tags": [
      "Categorical",
      "Circular",
      "Comparison",
      "Percentages",
      "Proportional",
      "ECharts",
      "Nightingale"
    ]
  },
  "query_compilation": {
    "frontend_builder": "D:/vsx/sources/superset-6.0.0/superset-frontend/plugins/plugin-chart-echarts/src/Pie/buildQuery.ts",
    "query_context_builder": "D:/vsx/sources/superset-6.0.0/superset-frontend/packages/superset-ui-core/src/query/buildQueryContext.ts",
    "query_field_aliases": {
      "metric": "metrics",
      "groupby": "columns"
    },
    "base_query_effect": "`buildQueryObject()` 会从 raw form_data 提取 `metric`、`groupby`、`adhoc_filters`、`row_limit` 等字段，生成 query `metrics` / `columns` / filters。",
    "pie_build_query_effect": "`sort_by_metric=true` 时会显式写入 `orderby=[[metric, false]]`；同时固定追加 `contribution` 后处理。",
    "frontend_post_processing": "`transformProps.ts` 会根据 `threshold_for_other` 把低占比切片聚合进 `Other`，并把 legend、label、donut、rose、show_total 等字段映射成 ECharts option。"
  },
  "control_overrides": {
    "series": {
      "validators": [
        "validateNonEmpty"
      ],
      "clearable": false,
      "notes": "当前 Pie controlPanel 未实际暴露该控件。"
    },
    "row_limit": {
      "default_value": 100
    }
  },
  "form_data_overrides": {
    "metric": "getStandardizedControls().shiftMetric()",
    "groupby": "getStandardizedControls().popAllColumns()",
    "row_limit": "ensureIsInt(formData.row_limit, 100) >= 100 ? 100 : formData.row_limit"
  },
