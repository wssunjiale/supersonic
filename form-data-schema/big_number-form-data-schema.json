  "conditional_blocks": {
    "temporal_filter_in_adhoc_filters": {
      "condition": "需要按时间范围过滤趋势线和大数字时",
      "fields": {
        "adhoc_filters": [
          {
            "clause": "WHERE",
            "subject": "<temporal_column>",
            "operator": "TEMPORAL_RANGE",
            "comparator": "Last 30 days",
            "expressionType": "SIMPLE"
          }
        ]
      }
    },
    "overall_value_across_full_range": {
      "condition": "需要展示整个筛选时间段上的总体值，而不是最后一个点时",
      "fields": {
        "aggregation": "raw"
      }
    },
    "comparison_summary": {
      "condition": "需要显示相对前一周期/前 N 周期的百分比摘要时",
      "fields": {
        "compare_lag": 1,
        "compare_suffix": "WoW"
      }
    },
    "show_timestamp": {
      "condition": "需要在大数字上方显示当前值对应的时间戳时",
      "fields": {
        "show_timestamp": true
      }
    },
    "fix_trendline_to_time_range": {
      "condition": "需要把趋势线补齐到完整时间范围边界时",
      "fields": {
        "time_range": "Last 30 days",
        "time_range_fixed": true
      }
    },
    "show_metric_name": {
      "condition": "需要在大数字上方显示指标名时",
      "fields": {
        "show_metric_name": true,
        "metric_name_font_size": 0.15
      }
    },
    "subtitle": {
      "condition": "需要在大数字下方显示补充说明时",
      "fields": {
        "subtitle": "Total Sales",
        "subtitle_font_size": 0.15
      }
    },
    "format_as_date": {
      "condition": "查询结果不是时间列类型，但仍希望按日期格式渲染时",
      "fields": {
        "time_format": "smart_date",
        "force_timestamp_formatting": true
      }
    },
    "rolling_window": {
      "condition": "需要先对时间序列做滚动窗口再得出 big number 时",
      "fields": {
        "rolling_type": "mean",
        "rolling_periods": 7,
        "min_periods": 7
      }
    },
    "resample": {
      "condition": "需要先对时间序列按固定频率重采样时",
      "fields": {
        "resample_rule": "1D",
        "resample_method": "ffill"
      }
    }
  },
  "runtime_only_or_non_template_fields": {
    "legacy_accepted_by_transform_props": [
      {
        "field_name": "subheader",
        "reason": "transformProps.ts 会在 compare_lag 没有生成比较摘要时回退读取 legacy 的 subheader，但当前 controlPanel 已不再暴露该字段。"
      }
    ],
    "runtime_derived_fields": [
      {
        "field_name": "subheader",
        "reason": "运行时优先由 compare_lag + compare_suffix 计算百分比摘要，不是当前推荐的 API 创建字段。"
      },
      {
        "field_name": "bigNumber",
        "reason": "运行时由查询结果计算得出，不是 form_data 字段。"
      },
      {
        "field_name": "bigNumberFallback",
        "reason": "运行时在当前值为空时回退到最近一个非空点，不是 form_data 字段。"
      },
      {
        "field_name": "timestamp",
        "reason": "运行时从排序后的时间序列里推导，不是 form_data 字段。"
      },
      {
        "field_name": "trendLineData",
        "reason": "运行时从 queriesData 组织出来的 ECharts 序列，不是 form_data 字段。"
      },
      {
        "field_name": "echartOptions",
        "reason": "运行时由 transformProps.ts 生成，不是 form_data 字段。"
      },
      {
        "field_name": "metricName",
        "reason": "运行时通过 getOriginalLabel(metric, datasource.metrics) 推导，用于显示友好指标名。"
      },
      {
        "field_name": "granularity_sqla",
        "reason": "BigNumberViz.tsx 的右键钻取事件读取 runtime formData.granularitySqla，但当前 controlPanel 的正式查询字段是 x_axis；新建图表模板不应把 granularity_sqla 当作主字段。"
      }
    ],
    "viz_switch_only": [
      {
        "field_name": "formDataOverrides(metric remap)",
        "reason": "只在 standardizedFormData.transform() 切换 viz_type 时触发，不是常规导出 Big Number with Trendline form_data 的必经步骤。"
      }
    ]
  },
  "api_usage_guidance": {
    "high_confidence_required_fields": [
      "datasource",
      "viz_type",
      "x_axis",
      "metric"
    ],
    "recommended_always_set": [
      "time_grain_sqla",
      "aggregation",
      "adhoc_filters",
      "show_trend_line",
      "y_axis_format",
      "time_format"
    ],
    "api_field_examples": [
      "x_axis",
      "metric",
      "aggregation",
      "compare_lag",
      "show_trend_line",
      "rolling_type",
      "resample_rule"
    ],
    "avoid_confusion": [
      "不要把 big_number 的 metric 写成 metrics 数组。",
      "不要把 granularity_sqla 当作当前图表创建时的主时间轴字段；controlPanel 的正式字段是 x_axis。",
      "不要优先传 runtime 生成的 subheader；如需比较摘要，应使用 compare_lag / compare_suffix。",
      "time_range_fixed 只有在 show_trend_line 有意义且存在时间范围上下文时才真正生效。",
      "如果你需要整个筛选区间的总体值，请把 aggregation 设为 raw，而不是假定 LAST_VALUE 会替你做整段聚合。"
    ]
  }
}
