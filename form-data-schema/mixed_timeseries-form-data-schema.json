  "conditional_blocks": {
    "query_b_secondary_axis": {
      "condition": "需要让 Query B 使用副轴时",
      "fields": {
        "yAxisIndexB": 1,
        "y_axis_bounds_secondary": [
          null,
          null
        ],
        "y_axis_format_secondary": "SMART_NUMBER",
        "currency_format_secondary": null,
        "yAxisTitleSecondary": "<secondary_axis_title>",
        "logAxisSecondary": false
      }
    },
    "query_type_mix": {
      "condition": "需要做折线 + 柱状、折线 + 散点等双图形混合时",
      "fields": {
        "seriesType": "line",
        "seriesTypeB": "bar",
        "area": false,
        "areaB": false,
        "stack": false,
        "stackB": false
      }
    },
    "query_a_advanced_analytics": {
      "condition": "只对 Query A 启用 rolling / time compare / resample 时",
      "fields": {
        "rolling_type": "mean",
        "rolling_periods": 7,
        "min_periods": 7,
        "time_compare": [
          "1 year ago"
        ],
        "comparison_type": "values",
        "resample_rule": "1D",
        "resample_method": "asfreq"
      }
    },
    "query_b_advanced_analytics": {
      "condition": "只对 Query B 启用 rolling / time compare / resample 时",
      "fields": {
        "rolling_type_b": "sum",
        "rolling_periods_b": 7,
        "min_periods_b": 7,
        "time_compare_b": [
          "1 year ago"
        ],
        "comparison_type_b": "difference",
        "resample_rule_b": "1D",
        "resample_method_b": "asfreq"
      }
    },
    "series_limit": {
      "condition": "需要分别限制 Query A 或 Query B 的 series 数量时",
      "fields": {
        "limit": 10,
        "timeseries_limit_metric": "<metric_or_adhoc_metric>",
        "order_desc": true,
        "limit_b": 5,
        "timeseries_limit_metric_b": "<metric_or_adhoc_metric_b>",
        "order_desc_b": true
      }
    },
    "show_query_identity": {
      "condition": "需要在 tooltip / 图例中明确标出 Query A 与 Query B 时",
      "fields": {
        "show_query_identifiers": true
      }
    },
    "markers_or_area": {
      "condition": "需要启用面积填充或 marker 时",
      "fields": {
        "area": true,
        "opacity": 0.2,
        "markerEnabled": true,
        "markerSize": 6,
        "areaB": false,
        "markerEnabledB": false
      }
    }
  },
  "runtime_only_or_non_template_fields": {
    "hidden_or_ineffective_fields": [
      {
        "field_name": "showTooltipTotal",
        "reason": "通过复用 richTooltipSection 注入，但 controls.tsx 的 visibility 已排除 VizType.MixedTimeseries，transformProps.ts 也不消费。"
      },
      {
        "field_name": "showTooltipPercentage",
        "reason": "通过复用 richTooltipSection 注入，但 controls.tsx 的 visibility 已排除 VizType.MixedTimeseries，transformProps.ts 也不消费。"
      },
      {
        "field_name": "truncateYAxisSecondary",
        "reason": "MixedTimeseries/types.ts 中存在，但 controlPanel.tsx 没有暴露输入控件，transformProps.ts 也没有单独读取它。"
      },
      {
        "field_name": "show_empty_columns / show_empty_columns_b",
        "reason": "buildQuery.test.ts 用它们覆盖 generic QueryFormData 行为，但当前 Mixed Chart controlPanel.tsx 并不暴露这两个控件，不放入推荐模板。"
      }
    ],
    "viz_switch_only": [
      {
        "field_name": "formDataOverrides(metrics/groupby remap)",
        "reason": "只在 standardized controls 切换 viz_type 时用来剔除与 Query B 重叠的 metrics / groupby，不是常规 API 构造 form_data 的必填字段。"
      }
    ],
    "high_risk_confusions": [
      {
        "field_name": "metrics_b vs metricsB",
        "reason": "API form_data 必须传 metrics_b；metricsB 只是 runtime camelCase 别名。"
      },
      {
        "field_name": "seriesTypeB vs seriesType_b",
        "reason": "Query B 样式字段实际是大写 B 后缀，不是 _b。"
      },
      {
        "field_name": "show_query_identifiers vs showQueryIdentifiers",
        "reason": "API form_data 使用蛇形命名，runtime formData 才会 camelCase。"
      }
    ]
  },
  "api_usage_guidance": {
    "high_confidence_required_fields": [
      "datasource",
      "viz_type",
      "x_axis",
      "metrics",
      "metrics_b"
