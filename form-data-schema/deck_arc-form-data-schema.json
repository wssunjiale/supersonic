  "api_usage_guidance": {
    "high_confidence_required_fields": [
      "datasource",
      "viz_type",
      "start_spatial",
      "end_spatial"
    ],
    "recommended_always_set": [
      "adhoc_filters",
      "filter_nulls",
      "row_limit",
      "mapbox_style",
      "viewport",
      "autozoom",
      "color_scheme_type",
      "stroke_width",
      "legend_position"
    ],
    "api_field_examples": [
      "start_spatial",
      "end_spatial",
      "mapbox_style",
      "viewport",
      "color_scheme_type",
      "dimension",
      "color_scheme",
      "stroke_width",
      "legend_position"
    ],
    "avoid_confusion": [
      "不要把 deck_arc 当成标准 chart data API 图表去套 `/api/v1/chart/data` 的 `query_context` 模板；当前图真实入口是 legacy `/superset/explore_json/`。",
      "不要给 deck_arc 人为添加并不存在的 `metric` 或 `size` 字段；当前图默认按列返回弧线记录。",
      "`start_spatial` 和 `end_spatial` 都是对象，不是单个列名字符串。根据你的空间数据编码方式，必须传 `latlong` / `delimited` / `geohash` 三种形状之一。",
      "只有 `color_scheme_type='categorical_palette'` 时，`dimension` 和 `color_scheme` 才真正决定颜色与图例。",
      "`viewport` 是正式保存态字段，但 `width`/`height` 由运行时补入，不要把这两个字段写回 root form_data。"
    ]
  }
