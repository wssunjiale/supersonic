  "conditional_blocks": {
    "delimited_spatial_columns": {
      "condition": "起点或终点空间字段存储在单列经纬度字符串中时",
      "fields": {
        "start_spatial": {
          "type": "delimited",
          "lonlatCol": "FROM_LONLAT",
          "delimiter": ",",
          "reverseCheckbox": false
        },
        "end_spatial": {
          "type": "delimited",
          "lonlatCol": "TO_LONLAT",
          "delimiter": ",",
          "reverseCheckbox": false
        }
      }
    },
    "geohash_spatial_columns": {
      "condition": "起点或终点空间字段存储为 geohash 时",
      "fields": {
        "start_spatial": {
          "type": "geohash",
          "geohashCol": "FROM_GEOHASH",
          "reverseCheckbox": false
        },
        "end_spatial": {
          "type": "geohash",
          "geohashCol": "TO_GEOHASH",
          "reverseCheckbox": false
        }
      }
    },
    "fixed_color_mode": {
      "condition": "需要弧线固定起点色和终点色时",
      "fields": {
        "color_scheme_type": "fixed_color",
        "color_picker": {
          "r": 0,
          "g": 122,
          "b": 135,
          "a": 1
        },
        "target_color_picker": {
          "r": 255,
          "g": 87,
          "b": 34,
          "a": 1
        }
      }
    },
    "categorical_palette_mode": {
      "condition": "需要按某个维度给弧线着色时",
      "fields": {
        "color_scheme_type": "categorical_palette",
        "dimension": "carrier",
        "color_scheme": "SUPERSET_DEFAULT",
        "legend_position": "tr",
        "legend_format": "SMART_NUMBER"
      }
    },
    "custom_js": {
      "condition": "需要自定义数据加工、tooltip 或点击跳转行为时",
      "fields": {
        "js_columns": [
          "carrier"
        ],
        "js_data_mutator": "data => data",
        "js_tooltip": "o => `<div>${o.object.cat_color}</div>`",
        "js_onclick_href": "o => `https://example.com/?from=${o.object.sourcePosition}&to=${o.object.targetPosition}`"
      }
    }
  },
