      },
      {
        "field_name": "yAXisFormat",
        "reason": "Bubble/types.ts 里的拼写错误。实际 API 主键是 y_axis_format，运行时别名是 yAxisFormat。"
      }
    ],
    "runtime_aliases_generated_by_ChartProps": [
      {
        "field_name": "showLegend",
        "reason": "由 raw form_data.show_legend 经 convertKeysToCamelCase() 生成。"
      },
      {
        "field_name": "maxBubbleSize",
