      "reason": "Heatmap guest 请求仍应保持 `heatmap_v2`。"
    },
    {
      "field_name": "x_axis",
      "reason": "会改变编译后的第一维 `columns`。"
    },
    {
      "field_name": "groupby",
      "reason": "会改变编译后的第二维 `columns`。"
    },
    {
      "field_name": "metric",
      "reason": "会改变编译后的 `metrics`。"
    },
    {
      "field_name": "sort_x_axis",
      "reason": "会改变编译后的 `orderby`。"
    },
    {
      "field_name": "sort_y_axis",
      "reason": "会改变编译后的 `orderby`。"
    },
    {
      "field_name": "normalize_across",
      "reason": "会改变 `rank` post_processing 的 `group_by` 语义。"
    },
    {
