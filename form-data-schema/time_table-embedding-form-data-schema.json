{
  "viz_type": "time_table",
  "display_name": "Time-series Table",
  "purpose": "第三方 embedding / guest token 场景下安全传输的 form_data 模板",
  "base_form_data_schema_file": "D:/vsx/metrics/supersonic/form-data-schema/time_table-form-data-schema.json",
  "source_files": [
