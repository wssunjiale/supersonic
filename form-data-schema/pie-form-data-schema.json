    "api_field_examples": [
      "metric",
      "groupby",
      "sort_by_metric",
      "threshold_for_other",
      "date_format",
      "legendOrientation",
      "roseType"
    ],
    "avoid_confusion": [
      "不要把 Pie Chart 的 root 指标字段写成 `metrics`；当前图的 control name 是 `metric`。",
      "不要把运行时 camelCase 名称 `colorScheme`、`dateFormat`、`showLabels`、`thresholdForOther`、`showLegend` 写回 root form_data。",
      "不要把 `row_limit` 当成共享控件的 10000；当前 Pie control override 会把它固定在 100 上限。",
      "不要把 `series` 当成当前图必传字段；它只是 controlOverrides 里的遗留项。"
    ]
  }
