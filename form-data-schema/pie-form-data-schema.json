  "api_usage_guidance": {
    "high_confidence_required_fields": [
      "datasource",
      "viz_type",
      "metric"
    ],
    "recommended_always_set": [
      "groupby",
      "adhoc_filters",
      "row_limit",
      "sort_by_metric",
      "color_scheme",
      "show_labels",
