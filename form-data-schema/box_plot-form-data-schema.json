    "filters": {
      "condition": "需要做普通或时间过滤时",
      "fields": {
        "adhoc_filters": [
          {
            "clause": "WHERE",
            "subject": "<filter_column>",
            "operator": "==",
            "comparator": "<value>",
            "expressionType": "SIMPLE"
          }
        ]
      }
    },
    "groupby_dimension": {
