  "runtime_only_or_non_template_fields": {
    "legacy_accepted_by_build_query": [
      {
        "field_name": "granularity_sqla",
        "reason": "BoxPlot/buildQuery.ts 在 columns 为空时，会把 legacy 的 granularity_sqla 当作回退分布列；当前 controlPanel 已不再把它作为正式主字段。"
      }
    ],
    "hidden_helper_fields": [
      {
        "field_name": "temporal_columns_lookup",
        "reason": "用于判断选中的物理列是否为时间列，从而决定是否把该列包装成带 timeGrain 的 AdhocColumn。通常由 UI 自动推导。"
      }
    ],
    "legacy_or_confusing_keys": [
      {
        "field_name": "whisker_options",
        "reason": "老的 Cypress 用例仍使用 whisker_options，但当前 BoxPlot controlPanel、types 和 boxplotOperator 的正式字段名是 whiskerOptions。"
      }
    ],
    "runtime_derived_fields": [
      {
        "field_name": "labelMap",
        "reason": "transformProps.ts 从查询结果构建交互映射，供 cross-filter / drill 行为使用，不是 form_data 字段。"
      },
      {
        "field_name": "selectedValues",
        "reason": "transformProps.ts 依据 filterState.selectedValues 计算图上高亮状态，不是 form_data 字段。"
      },
      {
        "field_name": "coltypeMapping",
        "reason": "运行时由查询结果列类型推导，用于格式化 groupby label，不是 form_data 字段。"
      },
      {
        "field_name": "echartOptions",
        "reason": "运行时由 transformProps.ts 生成，包括 boxplot series、outlier scatter series、tooltip 和 axis 配置。"
      }
    ],
    "viz_switch_only": [
      {
        "field_name": "formDataOverrides(columns/groupby remap)",
        "reason": "只在 standardizedFormData.transform() 切换 viz_type 时触发，用于把 standardized controls.columns 拆成最终的 columns 与 groupby，不是常规导出 Box Plot form_data 的必经步骤。"
      }
    ]
  },
  "api_usage_guidance": {
    "high_confidence_required_fields": [
      "datasource",
      "viz_type",
      "columns",
      "metrics"
    ],
    "recommended_always_set": [
      "adhoc_filters",
      "row_limit",
      "whiskerOptions",
      "color_scheme",
      "x_ticks_layout",
      "number_format",
      "date_format"
