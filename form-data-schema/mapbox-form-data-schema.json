    "api_field_examples": [
      "all_columns_x",
      "all_columns_y",
      "clustering_radius",
      "point_radius",
      "mapbox_label",
      "pandas_aggfunc",
      "mapbox_style"
    ],
    "avoid_confusion": [
      "不要把 `mapbox` 当成标准 chart data API 图去套 `/api/v1/chart/data` 的 `query_context` 模板。",
      "不要把 `mapbox_label` 当成真正的多标签数组；当前后端只读取第一项。",
      "不要把 camelCase 运行时字段名 `allColumnsX`、`mapboxStyle`、`globalOpacity` 写回 root form_data。",
      "不要假设 viewport 字段一定会决定初始地图中心；当前 6.0.0 实际是按 bounds 自动拟合。"
    ]
  }
