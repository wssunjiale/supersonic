  "conditional_blocks": {
    "grouped_map": {
      "condition": "需要按分类维度对点位进行聚合，并允许 `count` 或分组标签参与 cluster label 时",
      "fields": {
        "groupby": [
          "<group_dimension>",
          "<longitude_column>",
          "<latitude_column>"
        ],
        "mapbox_label": [
          "count"
        ]
      }
    },
    "custom_point_radius": {
      "condition": "需要按数据列控制单点半径时",
      "fields": {
        "point_radius": "<numeric_radius_column>",
        "point_radius_unit": "Pixels"
      },
      "notes": "若同时使用 groupby，后端要求 `<numeric_radius_column>` 已经存在于 `groupby`。"
    },
    "custom_label_column": {
      "condition": "需要用某个数值或维度列作为 cluster / point label 时",
      "fields": {
        "mapbox_label": [
          "<label_column>"
        ],
        "pandas_aggfunc": "sum"
      },
      "notes": "若存在 groupby，且 label 不是 `count`，后端要求该 label 列已经存在于 `groupby`。"
    },
    "disable_clustering": {
      "condition": "需要关闭聚类、直接渲染单点时",
      "fields": {
        "clustering_radius": "0"
      }
    },
    "visual_theme": {
      "condition": "需要切换底图样式、颜色和透明度时",
      "fields": {
        "mapbox_style": "mapbox://styles/mapbox/dark-v9",
        "mapbox_color": "rgb(255, 215, 0)",
        "global_opacity": 0.7
      }
    }
  },
  "runtime_only_or_non_template_fields": {
    "runtime_aliases_generated_by_transformProps": [
      {
        "field_name": "allColumnsX / allColumnsY / clusteringRadius / pointRadius / mapboxStyle / mapboxColor",
        "reason": "这些是 raw form_data 经过 ChartProps.convertKeysToCamelCase 后得到的运行时别名，不是 API root 键。"
      }
