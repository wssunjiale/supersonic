      },
      {
        "field_name": "queriesData[0].data.bounds",
        "reason": "这是后端按经纬度范围计算出的地图边界，不是 root form_data 字段。"
      }
    ],
    "legacy_request_wrapper": [
      {
        "field_name": "payload.form_data",
        "reason": "这是 legacy `/superset/explore_json/` 请求外层包裹字段，不是图表保存态内部的 root form_data 字段。"
      }
    ],
    "important_behavior_notes": [
      {
        "field_name": "viewport_longitude / viewport_latitude / viewport_zoom",
        "reason": "这些字段当前会被交互过程回写，但 `MapBox.jsx` 初始化时没有读取它们作为初始视口来源。"
      }
    ]
  },
  "api_usage_guidance": {
    "high_confidence_required_fields": [
      "datasource",
      "viz_type",
      "all_columns_x",
      "all_columns_y"
    ],
    "recommended_always_set": [
      "clustering_radius",
      "row_limit",
