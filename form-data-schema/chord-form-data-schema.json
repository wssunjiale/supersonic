  "minimal_form_data_template": {
    "datasource": "<dataset_id>__table",
    "viz_type": "chord",
    "groupby": "<source_dimension>",
    "columns": "<target_dimension>",
    "metric": "<metric_or_saved_metric>",
    "adhoc_filters": []
  },
  "recommended_form_data_template": {
    "datasource": "<dataset_id>__table",
    "viz_type": "chord",
    "groupby": "source_entity",
    "columns": "target_entity",
    "metric": {
      "expressionType": "SIMPLE",
      "column": {
        "column_name": "link_value"
      },
      "aggregate": "SUM",
      "label": "SUM(link_value)"
    },
    "adhoc_filters": [],
    "row_limit": 10000,
    "sort_by_metric": false,
    "y_axis_format": "SMART_NUMBER",
    "color_scheme": "SUPERSET_DEFAULT"
  },
  "conditional_blocks": {
    "filters": {
      "condition": "需要限制参与关系计算的底层数据时",
      "fields": {
        "adhoc_filters": [
          {
            "expressionType": "SIMPLE",
            "clause": "WHERE",
            "subject": "source_entity",
            "operator": "IN",
            "comparator": [
              "A"
            ]
          }
        ]
      }
    },
    "metric_sorting": {
      "condition": "需要按关系强度降序排序底层结果时",
      "fields": {
        "sort_by_metric": true
      }
    },
    "result_size_limit": {
      "condition": "需要控制参与构造弦图矩阵的最大关系边数时",
      "fields": {
        "row_limit": 1000
      }
    },
    "display_formatting": {
      "condition": "需要调整数值格式和节点配色时",
      "fields": {
        "y_axis_format": "SMART_NUMBER",
        "color_scheme": "SUPERSET_DEFAULT"
      }
    }
  },
