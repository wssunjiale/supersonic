{
  "viz_type": "echarts_timeseries_line",
  "display_name": "Line Chart",
  "purpose": "第三方 embedding / guest token 场景下安全传输的 form_data 模板",
  "base_form_data_schema_file": "D:/vsx/metrics/supersonic/form-data-schema/echarts_timeseries_line-form-data-schema.json",
  "source_files": [
    "D:/vsx/sources/superset-6.0.0/superset/security/manager.py",
    "D:/vsx/sources/superset-6.0.0/superset/constants.py",
    "D:/vsx/sources/superset-6.0.0/superset/utils/core.py",
    "D:/vsx/sources/superset-6.0.0/superset/charts/data/api.py",
    "D:/vsx/sources/superset-6.0.0/superset/commands/chart/data/get_data_command.py",
    "D:/vsx/sources/superset-6.0.0/superset/charts/schemas.py",
    "D:/vsx/sources/superset-6.0.0/superset-frontend/packages/superset-ui-core/src/query/constants.ts",
    "D:/vsx/sources/superset-6.0.0/superset-frontend/packages/superset-ui-core/src/query/types/QueryFormData.ts",
    "D:/vsx/sources/superset-6.0.0/superset-frontend/packages/superset-ui-core/src/query/processExtraFormData.ts",
    "D:/vsx/sources/superset-6.0.0/superset-frontend/src/dashboard/components/nativeFilters/utils.ts",
    "D:/vsx/sources/superset-6.0.0/superset-frontend/src/explore/controlUtils/getFormDataWithDashboardContext.ts",
    "D:/vsx/sources/superset-6.0.0/superset-frontend/plugins/plugin-chart-echarts/src/Timeseries/buildQuery.ts"
  ],
  "notes": [
    "embedded guest 的核心限制不在前端，而在后端 security/manager.py 的 query_context_modified()。报错原文是 `Guest user cannot modify chart payload`。",
    "安全做法不是重新拼装一份新的 Line Chart form_data，而是以已保存图表的 form_data 原样复制为 base，只把动态条件放进 extra_form_data。",
    "对于 Line Chart，第三方 embedding 最实用的动态入口是 extra_form_data，而不是改根层 metrics/groupby/x_axis 等图表定义字段。",
    "Line Chart 是标准 chart data API 图，x_axis 会进入 query.columns；timeseries_limit_metric / order_desc / x_axis_sort 等会间接影响 orderby。",
    "frontend 的 superset-ui-core 声明了 extra_form_data.time_compare，但 Superset 6.0.0 后端 constants.py 的 merge whitelist 并没有把它纳入高置信覆盖列表。guest embedding 下应视为不稳定/高风险字段。",
    "interactive_groupby / interactive_highlight / interactive_drilldown 在通用 ExtraFormData 类型中存在，但 Line 的 Timeseries/buildQuery.ts 不直接消费这些键，通常没有实际效果。"
  ],
  "security_enforcement": {
    "backend_check_function": "superset/security/manager.py::query_context_modified",
    "checked_when": "ChartDataCommand.validate() -> QueryContext.raise_for_access()",
    "error_message": "Guest user cannot modify chart payload",
    "hard_block_fields": [
      "slice_id",
      "metrics",
      "groupby",
      "columns",
      "orderby"
    ],
    "indirectly_sensitive_fields_for_line": [
      "x_axis",
      "timeseries_limit_metric",
      "order_desc",
      "x_axis_sort",
      "x_axis_sort_asc",
      "limit"
    ],
    "recommended_strategy": "复制保存态 chart form_data 作为 base，仅通过 extra_form_data 追加过滤与时间上下文。"
  },
  "safe_base_rule": {
    "description": "第三方 embedding 请求中的根层 form_data，应当从已保存图表的 form_data 直接复制，不要重构。",
    "must_be_copied_from_saved_chart": [
      "slice_id",
      "datasource",
      "viz_type",
      "x_axis",
      "metrics",
      "groupby",
      "adhoc_filters",
      "timeseries_limit_metric",
      "order_desc",
      "row_limit",
      "annotation_layers",
      "all other chart-definition fields"
    ],
    "why": [
      "query_context_modified() 会把请求中的 metrics/groupby/columns/orderby 与保存态图表对比。",
      "Line Chart 的 x_axis 会进入 query_context.queries.columns；即使后端没有直接比对 x_axis 字段，修改它仍会通过 queries.columns 差异触发越权。",
      "timeseries_limit_metric / order_desc / x_axis_sort 等排序相关字段会影响 query_context 中的 orderby，guest 模式下不应在根层主动改。"
    ]
  },
  "safe_embedding_form_data_template": {
    "description": "这是 guest embedding 下的安全写法。根层以保存态图表为 base，仅改 extra_form_data。",
    "template": {
      "slice_id": "<saved_chart_id>",
      "dashboardId": "<dashboard_id>",
      "datasource": "<copied_from_saved_chart>",
      "viz_type": "echarts_timeseries_line",
      "x_axis": "<copied_from_saved_chart>",
      "metrics": "<copied_from_saved_chart>",
      "groupby": "<copied_from_saved_chart>",
      "adhoc_filters": "<copied_from_saved_chart>",
      "timeseries_limit_metric": "<copied_from_saved_chart>",
      "order_desc": "<copied_from_saved_chart>",
      "row_limit": "<copied_from_saved_chart>",
      "extra_form_data": {
        "time_range": "Last 7 days",
        "time_grain_sqla": "P1D",
        "filters": [
          {
            "col": "region",
            "op": "IN",
            "val": [
              "East",
              "West"
            ]
          }
        ],
        "adhoc_filters": [
          {
            "expressionType": "SIMPLE",
            "clause": "WHERE",
            "subject": "region",
            "operator": "IN",
            "comparator": [
              "East",
              "West"
            ]
          }
        ],
        "custom_form_data": {}
      }
    }
  },
  "preferred_dynamic_container": {
    "field_name": "extra_form_data",
    "description": "第三方 embedding 允许动态传入的上下文容器；后端会在 merge_extra_form_data() 中把它并入实际查询。",
    "append_keys": [
      "adhoc_filters",
      "filters",
      "interactive_groupby",
      "interactive_highlight",
      "interactive_drilldown",
      "custom_form_data"
    ],
    "override_keys_backend_high_confidence": [
      "granularity_sqla",
      "granularity",
      "time_column",
      "time_grain",
      "time_range",
      "time_grain_sqla",
      "relative_start",
      "relative_end"
    ],
    "frontend_declared_but_backend_not_high_confidence": [
      "time_compare"
    ]
  },
  "extra_form_data_field_schema": [
    {
      "field_name": "time_range",
      "data_type": "string",
      "behavior": "override",
      "safe_for_line": true,
      "recommended": true,
      "sample_data": "Last 7 days",
      "effect": "覆盖保存态图表的时间范围。",
      "source": "superset/constants.py + superset/utils/core.py"
    },
    {
      "field_name": "time_grain_sqla",
      "data_type": "string | null",
      "behavior": "override",
      "safe_for_line": true,
      "recommended": true,
      "sample_data": "P1D",
      "effect": "覆盖时间粒度。",
      "source": "superset/constants.py + superset/utils/core.py"
    },
    {
      "field_name": "granularity_sqla",
      "data_type": "string | null",
      "behavior": "override",
      "safe_for_line": true,
      "recommended": false,
      "sample_data": "order_date",
      "effect": "覆盖时间列；对时序图属于高影响字段，仅在你明确知道保存态图表就是同一时间列语义时使用。",
      "source": "superset/constants.py + frontend QueryFormData.ts"
    },
    {
      "field_name": "granularity",
      "data_type": "string | null",
      "behavior": "override",
      "safe_for_line": false,
      "recommended": false,
      "sample_data": "__time",
      "effect": "通用 SQL 时间列覆盖键；Line Chart 常规场景通常不需要手动传。",
      "source": "superset/constants.py"
    },
    {
      "field_name": "time_column",
      "data_type": "string | null",
      "behavior": "override",
      "safe_for_line": false,
      "recommended": false,
      "sample_data": "order_date",
      "effect": "后端 QueryObject 允许的时间列覆盖键；Line Chart 常规场景通常优先使用保存态 x_axis 与 granularity_sqla。",
      "source": "superset/constants.py + frontend QueryFormData.ts"
    },
    {
      "field_name": "time_grain",
      "data_type": "string | null",
      "behavior": "override",
      "safe_for_line": false,
      "recommended": false,
      "sample_data": "P1D",
      "effect": "底层 QueryObject 的时间粒度键，通常不必与 time_grain_sqla 同时手工传。",
      "source": "superset/constants.py + frontend QueryFormData.ts"
    },
    {
      "field_name": "filters",
      "data_type": "array[QueryObjectFilterClause]",
      "behavior": "append",
      "safe_for_line": true,
      "recommended": true,
      "sample_data": [
        {
          "col": "region",
          "op": "IN",
          "val": [
            "East",
            "West"
          ]
        }
      ],
      "effect": "追加 simple filters；后端会转成额外过滤条件。",
      "source": "superset/constants.py + superset/utils/core.py"
    },
    {
      "field_name": "adhoc_filters",
      "data_type": "array[AdhocFilter]",
      "behavior": "append",
      "safe_for_line": true,
      "recommended": true,
      "sample_data": [
        {
          "expressionType": "SIMPLE",
          "clause": "WHERE",
          "subject": "region",
          "operator": "IN",
          "comparator": [
            "East",
            "West"
          ]
        }
      ],
      "effect": "追加 adhoc filters；后端会标记为 isExtra 并并入查询。",
      "source": "superset/constants.py + superset/utils/core.py"
    },
    {
      "field_name": "custom_form_data",
      "data_type": "object",
      "behavior": "append",
      "safe_for_line": true,
      "recommended": false,
      "sample_data": {},
      "effect": "可传非标准附加数据；Line Chart 默认 buildQuery/transformProps 不直接消费它。",
      "source": "superset/constants.py + frontend QueryFormData.ts"
    },
    {
      "field_name": "relative_start",
      "data_type": "string",
      "behavior": "override",
      "safe_for_line": true,
      "recommended": false,
      "sample_data": "now",
      "effect": "进入 query.extras.relative_start。后端 schema 对取值做了约束，示例为 `today` / `now`。",
      "source": "superset/charts/schemas.py + superset/utils/core.py"
    },
    {
      "field_name": "relative_end",
      "data_type": "string",
      "behavior": "override",
      "safe_for_line": true,
      "recommended": false,
      "sample_data": "today",
      "effect": "进入 query.extras.relative_end。后端 schema 对取值做了约束，示例为 `today` / `now`。",
      "source": "superset/charts/schemas.py + superset/utils/core.py"
    },
    {
      "field_name": "interactive_groupby",
      "data_type": "array[string]",
      "behavior": "append",
      "safe_for_line": false,
      "recommended": false,
      "sample_data": [
        "region"
      ],
      "effect": "通用 ExtraFormData 字段。Line Chart 的 Timeseries/buildQuery.ts 不直接消费它，通常没有实际效果。",
      "source": "frontend QueryFormData.ts + query/constants.ts"
    },
    {
      "field_name": "interactive_highlight",
      "data_type": "array[string]",
      "behavior": "append",
      "safe_for_line": false,
      "recommended": false,
      "sample_data": [
        "region"
      ],
      "effect": "通用交互字段；Line Chart 默认不直接消费。",
      "source": "frontend QueryFormData.ts + query/constants.ts"
    },
    {
      "field_name": "interactive_drilldown",
      "data_type": "array[string]",
      "behavior": "append",
      "safe_for_line": false,
      "recommended": false,
      "sample_data": [
        "region"
      ],
      "effect": "通用交互字段；Line Chart 默认不直接消费。",
      "source": "frontend QueryFormData.ts + query/constants.ts"
    },
    {
      "field_name": "time_compare",
      "data_type": "string | array[string]",
      "behavior": "override",
      "safe_for_line": false,
      "recommended": false,
      "sample_data": [
        "1 year ago"
      ],
      "effect": "frontend 类型声明存在，但 Superset 6.0.0 后端 constants.py 的 extra_form_data merge whitelist 未将其列为高置信 override。guest embedding 下容易出现前后端行为不一致。",
      "source": "frontend QueryFormData.ts + query/constants.ts",
      "status": "低置信，不建议在 guest embedding 中依赖"
    }
  ],
  "minimal_extra_form_data_template": {
    "time_range": "Last 7 days"
  },
  "recommended_extra_form_data_template": {
    "time_range": "Last 7 days",
    "time_grain_sqla": "P1D",
    "filters": [
      {
        "col": "region",
        "op": "IN",
        "val": [
          "East",
          "West"
        ]
      }
    ],
    "adhoc_filters": [
      {
        "expressionType": "SIMPLE",
        "clause": "WHERE",
        "subject": "region",
        "operator": "IN",
        "comparator": [
          "East",
          "West"
        ]
      }
    ],
    "custom_form_data": {}
  },
  "unsafe_root_form_data_changes": [
    {
      "field_name": "slice_id",
      "reason": "与保存态图表 id 不一致会被后端立即判定为请求了另一张图。"
    },
    {
      "field_name": "metrics",
      "reason": "security manager 显式比较 requested metrics 是否是 stored metrics 的子集；改动后会报 Guest user cannot modify chart payload。"
    },
    {
      "field_name": "groupby",
      "reason": "security manager 显式比较；改动后会报错。"
    },
    {
      "field_name": "columns",
      "reason": "security manager 显式比较；Line 的 query.columns 还会包含 x_axis。"
    },
    {
      "field_name": "orderby",
      "reason": "security manager 显式比较；排序变更会触发报错。"
    },
    {
      "field_name": "x_axis",
      "reason": "虽然不是直接显式比较字段，但它会进入 query_context.queries.columns，实际仍会触发越权。"
    },
    {
      "field_name": "viz_type",
      "reason": "embedded guest 不应把已分享图表改成另一种图。"
    },
    {
      "field_name": "datasource",
      "reason": "embedded guest 不应改图表绑定数据集。"
    },
    {
      "field_name": "area",
      "reason": "属于图表定义字段。即使不一定直接命中 query_context_modified() 的核心对比，guest 请求里也不建议临时切换。"
    },
    {
      "field_name": "opacity",
      "reason": "属于图表定义字段；保守做法应直接复制保存态图表，而不是在 guest 请求里切换显示形态。"
    },
    {
      "field_name": "markerEnabled",
      "reason": "属于图表定义字段；guest 场景下不要把保存态 line 定义改成另一种展示配置。"
    },
    {
      "field_name": "markerSize",
      "reason": "属于图表定义字段；guest 场景下不要把保存态 line 定义改成另一种展示配置。"
    }
  ],
  "practical_guidance": {
    "best_practice": [
      "先从保存态图表读取完整 form_data。",
      "根层字段保持不变。",
      "只在 extra_form_data 中放时间范围、粒度和附加过滤条件。",
      "如果只是想做第三方筛选联动，优先使用 filters / adhoc_filters / time_range / time_grain_sqla。"
    ],
    "avoid": [
      "不要在 guest embedding 请求里手工重写 metrics、groupby、x_axis、orderby。",
      "不要把运行时 camelCase 字段名当成 API 键名使用。",
      "不要依赖 frontend 有定义但 backend whitelist 不稳定的 extra_form_data.time_compare。",
      "不建议在 guest 请求里临时切换 area、opacity、markerEnabled、markerSize。"
    ]
  }
}
