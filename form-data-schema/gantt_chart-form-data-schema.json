  "conditional_blocks": {
    "series_grouping": {
      "condition": "需要把每个 gantt 条按某个维度着色分组时",
      "fields": {
        "series": "owner",
        "show_legend": true,
        "legendType": "scroll"
      },
      "notes": "`series` 同时影响 query.series_columns、颜色映射和 legend 内容。"
    },
    "split_category_into_subrows": {
      "condition": "需要把同一 y 轴类别下的不同 series 拆成子行时",
      "fields": {
        "series": "owner",
        "subcategories": true
      },
      "notes": "`subcategories=true` 时，`transformProps.ts` 会在每个 category 下为不同 series 分配独立索引。"
    },
    "show_runtime_toggle": {
      "condition": "希望图表顶部允许终端用户在 Plain/Subcategories 间切换时",
      "fields": {
        "show_extra_controls": true,
        "subcategories": false
      },
      "notes": "这个开关只影响前端 UI，不改变 buildQuery。"
    },
    "custom_tooltip_payload": {
      "condition": "需要在 tooltip 中展示额外列和数值时",
      "fields": {
        "tooltip_metrics": [
          {
            "expressionType": "SIMPLE",
            "column": {
              "column_name": "duration_sec"
            },
            "aggregate": "SUM",
            "label": "SUM(duration_sec)"
          }
        ],
        "tooltip_columns": [
          "status",
          "priority"
        ]
      },
      "notes": "`tooltip_metrics` 会进入 query.metrics；`tooltip_columns` 会进入 query.columns。"
    },
    "explicit_ordering": {
      "condition": "需要在查询层明确排序 gantt 记录时",
      "fields": {
        "order_by_cols": [
          "[\"start_time\",true]",
          "[\"task_name\",true]"
        ]
      },
      "notes": "每一项都必须是字符串化 JSON，而不是数组对象。"
    },
    "x_axis_window": {
      "condition": "需要限制 gantt 图的日内显示窗口时",
      "fields": {
        "x_axis_time_bounds": [
          "08:00:00",
          "19:00:00"
        ],
        "x_axis_time_format": "smart_date"
      },
      "notes": "当前源码按 `HH:mm:ss` 解析。上界实现存在 `Math.min(...end_time)` 的源码行为。"
    }
  },
  "runtime_only_or_non_template_fields": {
    "runtime_camel_case_aliases": [
      {
        "field_name": "startTime / endTime / yAxis",
        "reason": "分别对应 root `start_time`、`end_time`、`y_axis`。"
      },
      {
        "field_name": "tooltipMetrics / tooltipColumns",
        "reason": "分别对应 root `tooltip_metrics`、`tooltip_columns`。"
      },
      {
        "field_name": "xAxisTimeBounds / xAxisTimeFormat / showExtraControls / colorScheme / showLegend",
        "reason": "这些是 root 对应字段的运行时别名，不是创建 API root form_data 的正式键名。"
      }
    ],
    "query_context_generated_fields": [
      {
        "field_name": "query_context.queries[*].columns",
        "reason": "由 `start_time`、`end_time`、`y_axis`、`series`、`tooltip_columns` 和 `order_by_cols` 编译生成。"
      },
      {
        "field_name": "query_context.queries[*].metrics",
        "reason": "由 root `tooltip_metrics` 编译生成。"
      },
      {
        "field_name": "query_context.queries[*].orderby",
        "reason": "由 root `order_by_cols` 解析生成。"
      },
      {
        "field_name": "query_context.queries[*].series_columns",
        "reason": "由 root `series` 生成。"
      }
    ],
    "removed_shared_title_field": [
      {
        "field_name": "y_axis_title_position",
        "reason": "公共 `chartTitle.tsx` 定义了它，但 Gantt controlPanel 已显式移除，且 `transformProps.ts` 不使用它。"
      }
    ]
  },
  "api_usage_guidance": {
    "high_confidence_required_fields": [
      "datasource",
      "viz_type",
      "start_time",
      "end_time",
      "y_axis"
    ],
    "recommended_always_set": [
      "tooltip_metrics",
      "tooltip_columns",
      "adhoc_filters",
      "order_by_cols",
      "row_limit",
      "color_scheme",
      "show_legend",
      "legendType",
      "legendOrientation",
      "zoomable"
    ],
    "mixed_case_examples": [
      "start_time",
      "end_time",
      "y_axis",
      "tooltip_metrics",
      "tooltip_columns",
      "x_axis_time_bounds",
      "x_axis_time_format",
      "show_extra_controls",
      "legendType",
      "legendOrientation",
      "legendMargin",
      "tooltipTimeFormat",
      "tooltipValuesFormat"
    ],
    "avoid_confusion": [
      "不要把 `startTime`、`endTime`、`tooltipMetrics`、`showExtraControls` 当成 API root 键名。",
      "`order_by_cols` 不是数组元组，而是字符串数组；每个字符串内部才是 `[column_name, is_ascending]` JSON。",
      "`tooltip_metrics` 不是纯样式字段，它会直接改变 query.metrics。",
      "`y_axis_title_position` 虽然属于公共 title controls，但 Gantt 当前并未正式暴露。"
    ]
  }
}
