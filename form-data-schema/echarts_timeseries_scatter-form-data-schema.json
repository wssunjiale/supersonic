    "runtime_interpreted_fields": [
      {
        "field_name": "markerEnabled",
        "reason": "controlPanel 暴露了该字段，但 Scatter 运行时仍会强制 showSymbol=true；它不是控制散点是否绘制的可靠 API 开关。"
      }
