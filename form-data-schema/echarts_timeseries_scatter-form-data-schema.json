  "runtime_only_or_non_template_fields": {
    "runtime_injected": [
      {
        "field_name": "seriesType",
        "reason": "Scatter/index.ts 在运行时包装 transformProps 时注入 seriesType=Scatter，不是 controlPanel 导出的 API 模板字段。"
      }
