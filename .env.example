# StandaloneLauncher will load this file via spring.config.import.
# Use KEY=VALUE format. Do not add "export ".

# Local IDE startup default: use the embedded H2 database.
S2_DB_TYPE=h2

# PostgreSQL example
# S2_DB_TYPE=postgres
# S2_DB_HOST=127.0.0.1
# S2_DB_PORT=5432
# S2_DB_DATABASE=supersonic
# S2_DB_USER=supersonic
# S2_DB_PASSWORD=postgres

# MySQL example
# S2_DB_TYPE=mysql
# S2_DB_HOST=127.0.0.1
# S2_DB_PORT=3306
# S2_DB_DATABASE=supersonic
# S2_DB_USER=root
# S2_DB_PASSWORD=

# Common runtime settings
# S2_AGENT_SERVICE_RESPONSE_TIMEOUT_MINUTES=5

# Superset integration
# These variables are read by launchers/standalone/src/main/resources/s2-config.yaml.
# Leave them commented if you want to use the defaults from YAML.
# S2_SUPERSET_ENABLED=true
# S2_SUPERSET_BASE_URL=http://127.0.0.1:8088
# S2_SUPERSET_AUTH_ENABLED=true
# S2_SUPERSET_AUTH_STRATEGY=JWT_FIRST
# S2_SUPERSET_API_KEY=
# S2_SUPERSET_JWT_USERNAME=
# S2_SUPERSET_JWT_PASSWORD=
# S2_SUPERSET_JWT_PROVIDER=db
# S2_SUPERSET_TIMEOUT_SECONDS=30
# S2_SUPERSET_DATASOURCE_TYPE=table
# S2_SUPERSET_VIZ_TYPE_LLM_ENABLED=true
# S2_SUPERSET_VIZ_TYPE_LLM_TOP_N=3
# S2_SUPERSET_VIZ_TYPE_ALLOW_LIST=
# S2_SUPERSET_VIZ_TYPE_DENY_LIST=
# S2_SUPERSET_GUEST_USER_USERNAME=supersonic-guest
# S2_SUPERSET_GUEST_USER_FIRST_NAME=Supersonic
# S2_SUPERSET_GUEST_USER_LAST_NAME=Guest
# S2_SUPERSET_SYNC_ENABLED=true
# S2_SUPERSET_SYNC_AUTO_MIGRATE_REGISTRY_SCHEMA=true
# S2_SUPERSET_SYNC_INTERVAL_MS=3600000
# S2_SUPERSET_SYNC_DATASET_INTERVAL_MS=60000
# S2_SUPERSET_SYNC_RETRY_INTERVAL_MS=60000
# S2_SUPERSET_SYNC_MAX_RETRIES=3
# S2_SUPERSET_SYNC_REBUILD=false
